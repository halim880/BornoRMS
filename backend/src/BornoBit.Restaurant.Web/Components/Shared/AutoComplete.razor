@typeparam TItem

<div class="ac-wrap @Class" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="ac-label">@Label@if (Required) {<span class="ac-req">*</span>}</label>
    }
    <div class="ac-input-wrap @(_open ? "is-open" : "")">
        <input type="text"
               class="ac-input"
               @ref="_inputRef"
               placeholder="@Placeholder"
               value="@_input"
               disabled="@Disabled"
               autocomplete="off"
               spellcheck="false"
               @oninput="OnInput"
               @onkeydown="OnKeyDownAsync"
               @onfocus="OnFocus"
               @onblur="OnBlur" />
        @if (!Disabled && (!string.IsNullOrEmpty(_input) || (!ClearOnSelect && SelectedItem is not null)))
        {
            <button type="button" class="ac-clear" tabindex="-1" title="Clear"
                    @onmousedown:preventDefault="true"
                    @onmousedown:stopPropagation="true"
                    @onclick="ClearAsync">×</button>
        }
        <span class="ac-caret" aria-hidden="true">▾</span>
    </div>

    @if (_open)
    {
        <div class="ac-dropdown" @onmousedown:preventDefault="true">
            @if (_filtered.Count == 0)
            {
                <div class="ac-empty">No matches.</div>
            }
            else
            {
                @for (int i = 0; i < _filtered.Count; i++)
                {
                    var idx = i;
                    var item = _filtered[i];
                    <div class="ac-row @(idx == _highlight ? "ac-row-active" : "")"
                         @onclick="@(() => SelectAsync(item))"
                         @onmouseenter="@(() => _highlight = idx)">
                        @if (ItemTemplate is not null)
                        {
                            @ItemTemplate(item)
                        }
                        else
                        {
                            <span>@ItemText(item)</span>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<TItem> Items { get; set; } = Array.Empty<TItem>();
    [Parameter] public TItem? SelectedItem { get; set; }
    [Parameter] public EventCallback<TItem?> SelectedItemChanged { get; set; }
    [Parameter] public EventCallback<TItem> OnItemSelected { get; set; }
    [Parameter] public EventCallback OnEnter { get; set; }
    [Parameter, EditorRequired] public Func<TItem, string> ItemText { get; set; } = default!;
    [Parameter] public Func<TItem, string, bool>? ItemFilter { get; set; }
    [Parameter] public RenderFragment<TItem>? ItemTemplate { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ClearOnSelect { get; set; }
    [Parameter] public int MaxResults { get; set; } = 15;
    [Parameter] public int MinSearchLength { get; set; } = 1;
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Class { get; set; }

    private ElementReference _inputRef;
    private string _input = string.Empty;
    private bool _open;
    private int _highlight = -1;
    private List<TItem> _filtered = new();
    private TItem? _lastSyncedSelection;
    private bool _syncedOnce;

    public ValueTask FocusAsync() => _inputRef.FocusAsync();

    protected override void OnParametersSet()
    {
        if (ClearOnSelect) return;
        if (!_syncedOnce || !EqualityComparer<TItem?>.Default.Equals(SelectedItem, _lastSyncedSelection))
        {
            _lastSyncedSelection = SelectedItem;
            _input = SelectedItem is null ? string.Empty : ItemText(SelectedItem);
            _syncedOnce = true;
        }
    }

    private void Filter()
    {
        var q = _input ?? string.Empty;
        if (q.Length < MinSearchLength) { _filtered = new(); return; }
        Func<TItem, bool> pred = ItemFilter is not null
            ? (i => ItemFilter(i, q))
            : (i => ItemText(i)?.Contains(q, StringComparison.OrdinalIgnoreCase) == true);
        _filtered = Items.Where(pred).Take(MaxResults).ToList();
    }

    private void OnInput(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? string.Empty;
        Filter();
        _open = !string.IsNullOrEmpty(_input);
        _highlight = _filtered.Count > 0 ? 0 : -1;
    }

    private void OnFocus()
    {
        if (!string.IsNullOrEmpty(_input))
        {
            Filter();
            _open = true;
            if (_filtered.Count > 0 && _highlight < 0) _highlight = 0;
        }
    }

    private void OnBlur()
    {
        _open = false;
        if (!ClearOnSelect)
        {
            _input = SelectedItem is null ? string.Empty : ItemText(SelectedItem);
        }
    }

    private async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (!_open) { Filter(); _open = !string.IsNullOrEmpty(_input); }
                if (_filtered.Count == 0) return;
                _highlight = (_highlight + 1) % _filtered.Count;
                break;
            case "ArrowUp":
                if (!_open) { Filter(); _open = !string.IsNullOrEmpty(_input); }
                if (_filtered.Count == 0) return;
                _highlight = _highlight <= 0 ? _filtered.Count - 1 : _highlight - 1;
                break;
            case "Enter":
                if (_open && _highlight >= 0 && _highlight < _filtered.Count)
                {
                    await SelectAsync(_filtered[_highlight]);
                }
                else
                {
                    _open = false;
                }
                if (OnEnter.HasDelegate) await OnEnter.InvokeAsync();
                break;
            case "Escape":
            case "Tab":
                _open = false;
                break;
        }
    }

    private async Task SelectAsync(TItem item)
    {
        if (ClearOnSelect)
        {
            _input = string.Empty;
            _filtered = new();
            _highlight = -1;
            _open = false;
        }
        else
        {
            _input = ItemText(item);
            _open = false;
            _lastSyncedSelection = item;
            if (SelectedItemChanged.HasDelegate) await SelectedItemChanged.InvokeAsync(item);
        }
        if (OnItemSelected.HasDelegate) await OnItemSelected.InvokeAsync(item);
    }

    private async Task ClearAsync()
    {
        _input = string.Empty;
        _filtered = new();
        _highlight = -1;
        _open = false;
        if (!ClearOnSelect)
        {
            _lastSyncedSelection = default;
            if (SelectedItemChanged.HasDelegate) await SelectedItemChanged.InvokeAsync(default);
        }
    }
}

<style>
    .ac-wrap { position: relative; display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .ac-label {
        font-size: 11px; font-weight: 600;
        color: #475569;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .ac-req { color: var(--hc-primary); margin-left: 2px; }

    .ac-input-wrap { position: relative; display: flex; align-items: center; }
    .ac-input {
        width: 100%;
        padding: 9px 50px 9px 12px;
        font-size: 13px; line-height: 1.3;
        border: 1px solid #E2E8F0; border-radius: 8px;
        background: #fff; color: #0F172A;
        outline: none;
        transition: border-color 100ms, box-shadow 100ms;
        font-family: inherit;
    }
    .ac-input::placeholder { color: #94A3B8; }
    .ac-input:focus { border-color: #94A3B8; box-shadow: 0 0 0 3px rgba(148,163,184,0.18); }
    .ac-input-wrap.is-open .ac-input { border-color: #CBD5E1; }
    .ac-input:disabled { background: #F8FAFC; color: #94A3B8; cursor: not-allowed; }

    .ac-clear {
        position: absolute; right: 30px;
        width: 22px; height: 22px;
        border: 0; background: transparent;
        color: #94A3B8;
        font-size: 16px; line-height: 1;
        cursor: pointer; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 100ms, color 100ms;
    }
    .ac-clear:hover { background: #F1F5F9; color: #0F172A; }

    .ac-caret {
        position: absolute; right: 12px;
        color: #94A3B8;
        font-size: 11px;
        pointer-events: none;
    }

    .ac-dropdown {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0;
        z-index: 50;
        max-height: 280px; overflow-y: auto;
        background: #fff;
        border: 1px solid #E2E8F0; border-radius: 10px;
        box-shadow: 0 8px 24px -12px rgba(15,23,42,0.18);
        padding: 4px;
    }

    .ac-row {
        padding: 8px 10px;
        border-radius: 6px;
        font-size: 13px;
        color: #0F172A;
        cursor: pointer;
        display: flex; align-items: center; gap: 10px;
    }
    .ac-row:hover { background: #F8FAFC; }
    .ac-row-active { background: #FEF2F2; }

    .ac-empty {
        padding: 14px 10px;
        text-align: center;
        color: #94A3B8;
        font-size: 13px;
    }
</style>
