@namespace BornoBit.Restaurant.Web.Components.BornoUi
@typeparam T

<div class="bo-cmp-field @(string.IsNullOrEmpty(Error) ? "" : "is-invalid") @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bo-cmp-field-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bo-cmp-field-required" aria-hidden="true">*</span>
            }
        </label>
    }
    <div class="bo-cmp-numeric @(Disabled ? "is-disabled" : "") @(ReadOnly ? "is-readonly" : "")">
        @if (!string.IsNullOrEmpty(Prefix))
        {
            <span class="bo-cmp-numeric-affix bo-cmp-numeric-prefix">@Prefix</span>
        }
        <input id="@_id"
               type="text"
               inputmode="decimal"
               class="bo-cmp-numeric-input"
               value="@FormatValue(Value)"
               placeholder="@Placeholder"
               disabled="@Disabled"
               readonly="@ReadOnly"
               @onchange="OnChange"
               @oninput="OnInput" />
        @if (!string.IsNullOrEmpty(Suffix))
        {
            <span class="bo-cmp-numeric-affix bo-cmp-numeric-suffix">@Suffix</span>
        }
        @if (ShowStepper && !ReadOnly)
        {
            <div class="bo-cmp-numeric-stepper">
                <button type="button" tabindex="-1"
                        class="bo-cmp-numeric-step-btn"
                        disabled="@Disabled"
                        @onclick="StepUp"
                        aria-label="Increase">
                    <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m4 10 4-4 4 4" />
                    </svg>
                </button>
                <button type="button" tabindex="-1"
                        class="bo-cmp-numeric-step-btn"
                        disabled="@Disabled"
                        @onclick="StepDown"
                        aria-label="Decrease">
                    <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m4 6 4 4 4-4" />
                    </svg>
                </button>
            </div>
        }
    </div>
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="bo-cmp-field-error">@Error</div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="bo-cmp-field-hint">@Hint</div>
    }
</div>

@code {
    [Parameter] public T? Value { get; set; }
    [Parameter] public EventCallback<T> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Prefix { get; set; }
    [Parameter] public string? Suffix { get; set; }
    [Parameter] public string? Min { get; set; }
    [Parameter] public string? Max { get; set; }
    [Parameter] public string? Step { get; set; }
    [Parameter] public int Decimals { get; set; } = 0;
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Immediate { get; set; }
    [Parameter] public bool ShowStepper { get; set; } = true;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private readonly string _id = $"bo-numeric-{Guid.NewGuid():N}";

    private string? FormatValue(T? value)
    {
        if (value is null) return null;
        if (value is IFormattable f)
            return f.ToString($"F{Decimals}", System.Globalization.CultureInfo.InvariantCulture);
        return value.ToString();
    }

    private async Task OnChange(ChangeEventArgs e)
    {
        if (!Immediate) await EmitAsync(e.Value?.ToString());
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        if (Immediate) await EmitAsync(e.Value?.ToString());
    }

    private async Task EmitAsync(string? raw)
    {
        var clean = raw?.Replace(",", "");
        if (string.IsNullOrWhiteSpace(clean))
        {
            await ValueChanged.InvokeAsync(default!);
            return;
        }
        if (TryConvert(clean, out var converted))
            await ValueChanged.InvokeAsync(converted);
    }

    private async Task StepUp()
    {
        if (Disabled || ReadOnly) return;
        var next = (ToDecimal(Value) ?? 0m) + ParseDecimal(Step, 1m);
        var max = ParseDecimal(Max, null);
        if (max.HasValue && next > max.Value) next = max.Value;
        if (TryConvert(next, out var converted)) await ValueChanged.InvokeAsync(converted);
    }

    private async Task StepDown()
    {
        if (Disabled || ReadOnly) return;
        var next = (ToDecimal(Value) ?? 0m) - ParseDecimal(Step, 1m);
        var min = ParseDecimal(Min, null);
        if (min.HasValue && next < min.Value) next = min.Value;
        if (TryConvert(next, out var converted)) await ValueChanged.InvokeAsync(converted);
    }

    private static decimal ParseDecimal(string? raw, decimal fallback)
    {
        if (string.IsNullOrWhiteSpace(raw)) return fallback;
        var clean = raw.TrimEnd('m', 'M');
        return decimal.TryParse(clean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : fallback;
    }

    private static decimal? ParseDecimal(string? raw, decimal? fallback)
    {
        if (string.IsNullOrWhiteSpace(raw)) return fallback;
        var clean = raw.TrimEnd('m', 'M');
        return decimal.TryParse(clean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : fallback;
    }

    private static decimal? ToDecimal(T? value)
    {
        if (value is null) return null;
        try { return Convert.ToDecimal(value, System.Globalization.CultureInfo.InvariantCulture); }
        catch { return null; }
    }

    private static bool TryConvert(object source, out T converted)
    {
        var t = Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T);
        try
        {
            converted = (T)Convert.ChangeType(source, t, System.Globalization.CultureInfo.InvariantCulture);
            return true;
        }
        catch (FormatException) { converted = default!; return false; }
        catch (OverflowException) { converted = default!; return false; }
        catch (InvalidCastException) { converted = default!; return false; }
    }
}
