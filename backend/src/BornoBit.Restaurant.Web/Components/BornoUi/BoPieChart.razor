@*
    Lightweight SVG donut chart, generic over TItem. No external dependencies.

        <BoPieChart TItem="CategorySalesDto"
                    Data="@_byCategory"
                    ValueSelector="c => (double)c.Revenue"
                    LabelSelector="c => c.Category"
                    ValueFormat='v => v.ToString("#,##0")' />
*@
@typeparam TItem
@namespace BornoBit.Restaurant.Web.Components.BornoUi

@if (Data is null || _total <= 0)
{
    <div class="bo-area-empty" style="height:@(Height)px;">@EmptyText</div>
}
else
{
    <div class="bo-pie" style="display:flex; gap:18px; align-items:center; flex-wrap:wrap;">
        <svg width="@Height" height="@Height" viewBox="0 0 42 42" role="img" aria-label="@(Label ?? "Distribution")" style="flex:0 0 auto;">
            <circle cx="21" cy="21" r="@R" fill="none" stroke="var(--bo-border-soft, #EEF2F7)" stroke-width="6" />
            @{
                double acc = 0;
                var i = 0;
            }
            @foreach (var s in _slices)
            {
                var dash = s.Fraction * _circ;
                var offset = _circ * 0.25 - acc; // start at top (12 o'clock)
                <circle cx="21" cy="21" r="@R" fill="none"
                        stroke="@Palette[i % Palette.Length]" stroke-width="6"
                        stroke-dasharray="@Fmt(dash) @Fmt(_circ - dash)"
                        stroke-dashoffset="@Fmt(offset)"
                        stroke-linecap="butt" />
                acc += dash;
                i++;
            }
            <text x="21" y="20.5" text-anchor="middle" font-size="4" font-weight="700" fill="var(--bo-text, #0f172a)">@_slices.Count</text>
            <text x="21" y="25" text-anchor="middle" font-size="2.4" fill="var(--bo-text-subtle, #64748b)">@SegmentsLabel</text>
        </svg>

        <div class="bo-pie-legend" style="display:flex; flex-direction:column; gap:6px; min-width:140px; flex:1 1 auto;">
            @{ var li = 0; }
            @foreach (var s in _slices)
            {
                <div style="display:flex; align-items:center; gap:8px; font-size:var(--bo-font-sm);">
                    <span style="width:10px; height:10px; border-radius:3px; flex:0 0 auto; background:@Palette[li % Palette.Length];"></span>
                    <span style="flex:1 1 auto; color:var(--bo-text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@s.Label</span>
                    <span style="font-weight:600;">@(ValueFormat is null ? s.Value.ToString("#,##0") : ValueFormat(s.Value))</span>
                    <span style="color:var(--bo-text-subtle); width:42px; text-align:right;">@((s.Fraction * 100).ToString("0.0"))%</span>
                </div>
                li++;
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<TItem>? Data { get; set; }
    [Parameter, EditorRequired] public Func<TItem, double> ValueSelector { get; set; } = default!;
    [Parameter, EditorRequired] public Func<TItem, string> LabelSelector { get; set; } = default!;
    [Parameter] public Func<double, string>? ValueFormat { get; set; }
    [Parameter] public int Height { get; set; } = 160;
    [Parameter] public string? Label { get; set; }
    [Parameter] public string SegmentsLabel { get; set; } = "groups";
    [Parameter] public string EmptyText { get; set; } = "No data";
    [Parameter] public string[] Palette { get; set; } =
    {
        "var(--bo-primary, #0E7490)", "var(--bo-info, #2563EB)", "var(--bo-success, #16A34A)",
        "var(--bo-warning, #D97706)", "var(--bo-danger, #DC2626)", "#7C3AED", "#0891B2", "#DB2777"
    };

    private const double R = 15.915; // circumference ≈ 100 for r=15.915
    private double _circ;
    private double _total;
    private List<(string Label, double Value, double Fraction)> _slices = new();

    protected override void OnParametersSet()
    {
        _circ = 2 * Math.PI * R;
        _slices = new();
        _total = 0;
        if (Data is null) return;

        var raw = Data.Select(d => (Label: LabelSelector(d), Value: Math.Max(0, ValueSelector(d))))
                      .Where(x => x.Value > 0).ToList();
        _total = raw.Sum(x => x.Value);
        if (_total <= 0) return;

        _slices = raw.Select(x => (x.Label, x.Value, x.Value / _total)).ToList();
    }

    private static string Fmt(double v) => v.ToString("F3", System.Globalization.CultureInfo.InvariantCulture);
}
