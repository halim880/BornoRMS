@namespace BornoBit.Restaurant.Web.Components.BornoUi

<span class="bo-cmp-spinner bo-cmp-spinner--@Size @CssClass" role="status" aria-label="@(Label ?? "Loading")"></span>

@code {
    /// <summary>sm | md | lg</summary>
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string? Label { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
}
