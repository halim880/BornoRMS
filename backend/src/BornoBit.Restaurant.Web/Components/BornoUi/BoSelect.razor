@namespace BornoBit.Restaurant.Web.Components.BornoUi
@typeparam TOption

<div class="bo-cmp-field bo-cmp-select-wrap @(string.IsNullOrEmpty(Error) ? "" : "is-invalid") @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bo-cmp-field-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bo-cmp-field-required" aria-hidden="true">*</span>
            }
        </label>
    }
    <div class="bo-cmp-select-shell">
        <select id="@_id"
                class="bo-cmp-field-input bo-cmp-select"
                disabled="@Disabled"
                @onchange="OnSelectChange">
            @if (!string.IsNullOrEmpty(Placeholder))
            {
                <option value="" disabled selected="@(SelectedOption is null)">@Placeholder</option>
            }
            @if (Items is not null)
            {
                @foreach (var item in Items)
                {
                    var v = OptionValue(item);
                    var selected = SelectedOption is not null && OptionValue(SelectedOption) == v;
                    <option value="@v" selected="@selected">@OptionText(item)</option>
                }
            }
        </select>
        <span class="bo-cmp-select-chevron" aria-hidden="true">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="m4 6 4 4 4-4" />
            </svg>
        </span>
    </div>
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="bo-cmp-field-error">@Error</div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="bo-cmp-field-hint">@Hint</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<TOption>? Items { get; set; }
    [Parameter, EditorRequired] public Func<TOption, string> OptionValue { get; set; } = _ => "";
    [Parameter, EditorRequired] public Func<TOption, string> OptionText { get; set; } = _ => "";
    [Parameter] public TOption? SelectedOption { get; set; } = default;
    [Parameter] public EventCallback<TOption?> SelectedOptionChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private readonly string _id = $"bo-sel-{Guid.NewGuid():N}";

    private async Task OnSelectChange(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw)) { await SelectedOptionChanged.InvokeAsync(default!); return; }
        if (Items is null) { await SelectedOptionChanged.InvokeAsync(default!); return; }

        TOption? match = default;
        foreach (var item in Items)
        {
            if (OptionValue(item) == raw) { match = item; break; }
        }
        await SelectedOptionChanged.InvokeAsync(match!);
    }
}
