@namespace BornoBit.Restaurant.Web.Components.BornoUi
@typeparam T

<div class="bo-cmp-field @(string.IsNullOrEmpty(Error) ? "" : "is-invalid") @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bo-cmp-field-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bo-cmp-field-required" aria-hidden="true">*</span>
            }
        </label>
    }
    <input id="@_id"
           type="number"
           class="bo-cmp-field-input"
           value="@FormatValue(Value)"
           placeholder="@Placeholder"
           min="@Min"
           max="@Max"
           step="@Step"
           disabled="@Disabled"
           readonly="@ReadOnly"
           inputmode="decimal"
           @onchange="OnChange"
           @oninput="OnInput"
           @attributes="AdditionalAttributes" />
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="bo-cmp-field-error">@Error</div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="bo-cmp-field-hint">@Hint</div>
    }
</div>

@code {
    [Parameter] public T? Value { get; set; }
    [Parameter] public EventCallback<T> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Min { get; set; }
    [Parameter] public string? Max { get; set; }
    [Parameter] public string Step { get; set; } = "any";
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Immediate { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private readonly string _id = $"bo-num-{Guid.NewGuid():N}";

    private static string? FormatValue(T? value) =>
        value is null ? null : Convert.ToString(value, System.Globalization.CultureInfo.InvariantCulture);

    private async Task OnChange(ChangeEventArgs e)
    {
        if (!Immediate) await EmitAsync(e.Value?.ToString());
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        if (Immediate) await EmitAsync(e.Value?.ToString());
    }

    private async Task EmitAsync(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            await ValueChanged.InvokeAsync(default!);
            return;
        }
        try
        {
            var converted = (T)Convert.ChangeType(raw, Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T),
                System.Globalization.CultureInfo.InvariantCulture);
            await ValueChanged.InvokeAsync(converted);
        }
        catch (FormatException) { /* ignore parse errors during typing */ }
        catch (OverflowException) { /* ignore */ }
        catch (InvalidCastException) { /* ignore */ }
    }
}
