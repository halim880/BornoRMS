@namespace BornoBit.Restaurant.Web.Components.BornoUi

<div class="bo-cmp-field @(string.IsNullOrEmpty(Error) ? "" : "is-invalid") @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="bo-cmp-field-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="bo-cmp-field-required" aria-hidden="true">*</span>
            }
        </label>
    }
    <input id="@_id"
           type="date"
           class="bo-cmp-field-input"
           value="@FormatValue()"
           min="@Min"
           max="@Max"
           disabled="@Disabled"
           readonly="@ReadOnly"
           @onchange="OnDateChange" />
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="bo-cmp-field-error">@Error</div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="bo-cmp-field-hint">@Hint</div>
    }
</div>

@code {
    /// <summary>Bind a DateOnly?</summary>
    [Parameter] public DateOnly? Value { get; set; }
    [Parameter] public EventCallback<DateOnly?> ValueChanged { get; set; }

    /// <summary>Alternative: bind a DateTime? (legacy form models).</summary>
    [Parameter] public DateTime? DateTimeValue { get; set; }
    [Parameter] public EventCallback<DateTime?> DateTimeValueChanged { get; set; }

    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Min { get; set; }
    [Parameter] public string? Max { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private readonly string _id = $"bo-date-{Guid.NewGuid():N}";

    private string? FormatValue()
    {
        if (Value.HasValue) return Value.Value.ToString("yyyy-MM-dd");
        if (DateTimeValue.HasValue) return DateTimeValue.Value.ToString("yyyy-MM-dd");
        return null;
    }

    private async Task OnDateChange(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(null);
            if (DateTimeValueChanged.HasDelegate) await DateTimeValueChanged.InvokeAsync(null);
            return;
        }
        if (DateOnly.TryParse(raw, System.Globalization.CultureInfo.InvariantCulture, out var parsedDate))
        {
            if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(parsedDate);
            if (DateTimeValueChanged.HasDelegate)
                await DateTimeValueChanged.InvokeAsync(parsedDate.ToDateTime(TimeOnly.MinValue, DateTimeKind.Utc));
        }
    }
}
