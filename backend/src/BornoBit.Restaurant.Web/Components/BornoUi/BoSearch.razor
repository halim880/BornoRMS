@namespace BornoBit.Restaurant.Web.Components.BornoUi
@implements IDisposable

<div class="bo-cmp-search @CssClass">
    <span class="bo-cmp-search-icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="7" cy="7" r="5" />
            <path d="m13 13-2.5-2.5" />
        </svg>
    </span>
    <input type="search"
           class="bo-cmp-search-input"
           value="@Value"
           placeholder="@Placeholder"
           disabled="@Disabled"
           autocomplete="off"
           spellcheck="false"
           @oninput="OnInputChanged" />
    @if (!string.IsNullOrEmpty(Value))
    {
        <button type="button" class="bo-cmp-search-clear" title="Clear" @onclick="ClearAsync">×</button>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Debounce delay in ms; default 0 = fire immediately.</summary>
    [Parameter] public int DebounceMs { get; set; } = 0;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private System.Threading.Timer? _debounceTimer;

    private void OnInputChanged(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (DebounceMs <= 0)
        {
            _ = ValueChanged.InvokeAsync(v);
            return;
        }

        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() => ValueChanged.InvokeAsync(v));
        }, null, DebounceMs, System.Threading.Timeout.Infinite);
    }

    private async Task ClearAsync() => await ValueChanged.InvokeAsync(string.Empty);

    public void Dispose() => _debounceTimer?.Dispose();
}
