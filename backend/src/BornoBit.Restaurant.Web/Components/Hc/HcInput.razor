@namespace BornoBit.Restaurant.Web.Components.Hc

<div class="hc-cmp-field @(string.IsNullOrEmpty(Error) ? "" : "is-invalid") @CssClass">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="hc-cmp-field-label" for="@_id">
            @Label
            @if (Required)
            {
                <span class="hc-cmp-field-required" aria-hidden="true">*</span>
            }
        </label>
    }
    <input id="@_id"
           type="@Type"
           class="hc-cmp-field-input"
           value="@Value"
           placeholder="@Placeholder"
           maxlength="@(Maxlength > 0 ? Maxlength : 524288)"
           disabled="@Disabled"
           readonly="@ReadOnly"
           autocomplete="@Autocomplete"
           @oninput="OnInput"
           @onchange="OnChange"
           @attributes="AdditionalAttributes" />
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="hc-cmp-field-error">@Error</div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="hc-cmp-field-hint">@Hint</div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public int Maxlength { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public string? Autocomplete { get; set; }
    /// <summary>If true, fire ValueChanged on every keystroke; else only on blur.</summary>
    [Parameter] public bool Immediate { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => AdditionalAttributes is { } a && a.TryGetValue("class", out var c) ? c?.ToString() ?? "" : "";
    private readonly string _id = $"hc-in-{Guid.NewGuid():N}";

    private async Task OnInput(ChangeEventArgs e)
    {
        if (Immediate) await ValueChanged.InvokeAsync(e.Value?.ToString());
    }

    private async Task OnChange(ChangeEventArgs e)
    {
        if (!Immediate) await ValueChanged.InvokeAsync(e.Value?.ToString());
    }
}
