@namespace BornoBit.Restaurant.Web.Components.Hc
@implements IDisposable
@inject IJSRuntime JS

<div class="hc-pop-root">
    <span class="hc-pop-anchor" @onclick="Toggle" @onclick:stopPropagation="true">
        @Trigger
    </span>
    @if (_open)
    {
        <div class="hc-pop-backdrop" @onclick="Close"></div>
        <div class="hc-pop-flyout" style="@FlyoutStyle()" @onclick:stopPropagation="true">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public RenderFragment Trigger { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>start | end | center — horizontal alignment of flyout vs anchor.</summary>
    [Parameter] public string Align { get; set; } = "start";
    [Parameter] public int MinWidth { get; set; } = 200;
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    private bool _open;

    protected override void OnParametersSet()
    {
        _open = Open;
    }

    private async Task Toggle()
    {
        _open = !_open;
        await OpenChanged.InvokeAsync(_open);
    }

    public async Task Close()
    {
        if (!_open) return;
        _open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private string FlyoutStyle()
    {
        var s = $"min-width:{MinWidth}px;";
        s += Align switch
        {
            "end" => " right:0;",
            "center" => " left:50%; transform:translateX(-50%);",
            _ => " left:0;"
        };
        return s;
    }

    public void Dispose() { }
}
