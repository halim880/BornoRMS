@using BornoBit.Restaurant.Application.Products
@using BornoBit.Restaurant.Application.ProductCategories
@using BornoBit.Restaurant.Application.Inventory.Items
@using BornoBit.Restaurant.Application.Kitchen.Commands
@using BornoBit.Restaurant.Application.Kitchen.Queries
@using BornoBit.Restaurant.Domain.Catalog
@using BornoBit.Restaurant.Web.Services
@using FluentValidation
@using MediatR
@inject ISender Mediator
@inject IImageUploadService ImageUploadService
@inject IJSRuntime JS
@implements IAsyncDisposable

<BoDialogBody>
    <div @ref="_root" style="display:flex; flex-direction:column; gap:12px;">
        @if (!string.IsNullOrEmpty(_error))
        {
            <BoMessageBar Intent="error">@_error</BoMessageBar>
        }

        <BoInput Value="Content.Name" ValueChanged="OnNameChanged" Immediate="true" Label="Name" Required="true" Style="width:100%;" Maxlength="200" />
        <BoInput @bind-Value="Content.BanglaName" Label="Bangla name (বাংলা নাম)" Style="width:100%;" Maxlength="200" />

        <div style="display:flex; gap:12px;">
            <BoInput Value="Content.Code" ValueChanged="OnCodeChanged" Immediate="true" Label="Code / SKU" Required="true" Style="flex:1;" Maxlength="40"
                     Hint="Unique product code. Auto-filled from the name — edit if you prefer your own." />
            <BoNumeric T="int" @bind-Value="Content.DisplayOrder" Label="Display order" Style="width:140px;" Min="0" Step="1" />
        </div>

        <BoAutocomplete TOption="ProductCategoryDto"
                        Items="@_categories"
                        OptionValue="@(c => c.Id.ToString())"
                        OptionText="@(c => c.Name)"
                        SelectedOption="@_selectedCategory"
                        SelectedOptionChanged="@(c => Content.ProductCategoryId = c?.Id ?? Guid.Empty)"
                        Label="Category"
                        Placeholder="Search a category…"
                        Required="true" />

        <BoNumeric T="decimal" @bind-Value="Content.Price" Label="Price (Tk)" Style="width:100%;" Min="0" Step="0.01" />

        <BoAutocomplete TOption="KitchenStationDto"
                        Items="@_stations"
                        OptionValue="@(s => s.Id.ToString())"
                        OptionText="@(s => s.Name)"
                        SelectedOption="@_selectedStation"
                        SelectedOptionChanged="@(s => Content.KitchenStationId = s?.Id)"
                        Label="Kitchen station"
                        Placeholder="All stations (unassigned)" />

        <BoTextArea @bind-Value="Content.Description" Label="Description" Rows="2" Maxlength="1000" />

        <div style="display:flex; gap:12px; align-items:flex-end;">
            <BoSelect TOption="MethodOption"
                      Items="@_methods"
                      OptionValue="@(o => ((int)o.Value).ToString())"
                      OptionText="@(o => o.Label)"
                      SelectedOption="@_selectedMethod"
                      SelectedOptionChanged="@(o => Content.InventoryMethod = o?.Value ?? InventoryMethod.None)"
                      Label="Stock impact" Style="flex:1;" />

            @if (Content.InventoryMethod == InventoryMethod.DirectStock && Content.Variants.Count == 0)
            {
                <div style="flex:1;">
                    <BoAutocomplete TOption="InventoryItemDto"
                                    Items="@_stockItems"
                                    OptionValue="@(i => i.Id.ToString())"
                                    OptionText="@(i => $"{i.Name} ({i.UnitCode})")"
                                    OptionSearch="@(i => $"{i.Name} {i.UnitCode}")"
                                    SelectedOption="@_stockItems.FirstOrDefault(i => i.Id == Content.LinkedInventoryItemId)"
                                    SelectedOptionChanged="@(i => Content.LinkedInventoryItemId = i?.Id)"
                                    Label="Stock item"
                                    Placeholder="Optional — leave blank to auto-create"
                                    Hint="Optional. Leave empty and a stock SKU is created automatically on save."
                                    DropUp="true" />
                </div>
            }
        </div>
        @if (Content.InventoryMethod == InventoryMethod.DirectStock && Content.Variants.Count > 0)
        {
            <div class="bo-cmp-field-hint">Each variant deducts its own stock item — pick one per size below.</div>
        }
        @if (Content.InventoryMethod == InventoryMethod.RecipeBased)
        {
            <div class="bo-cmp-field-hint">Define the ingredient list in Stock → Recipes.</div>
        }

        <div class="bo-cmp-field">
            <label class="bo-cmp-field-label">Variants (optional)</label>
            <div class="bo-cmp-field-hint" style="margin-bottom:6px;">
                Sizes or portions with their own price — e.g. Quarter / Half / Full, or Regular / Large.
                When a product has variants, the waiter must pick one and the base price is ignored.
            </div>
            @foreach (var row in Content.Variants)
            {
                <div style="display:flex; gap:8px; align-items:center; margin-bottom:6px;">
                    <BoInput @bind-Value="row.Name" Placeholder="e.g. Half" Style="flex:1;" Maxlength="100" />
                    <BoNumeric T="decimal" @bind-Value="row.Price" Style="width:130px;" Min="0" Step="0.01" />
                    @if (Content.InventoryMethod == InventoryMethod.DirectStock)
                    {
                        <div style="width:220px;">
                            <BoAutocomplete TOption="InventoryItemDto"
                                            Items="@_stockItems"
                                            OptionValue="@(i => i.Id.ToString())"
                                            OptionText="@(i => $"{i.Name} ({i.UnitCode})")"
                                            OptionSearch="@(i => $"{i.Name} {i.UnitCode}")"
                                            SelectedOption="@_stockItems.FirstOrDefault(i => i.Id == row.LinkedInventoryItemId)"
                                            SelectedOptionChanged="@(i => row.LinkedInventoryItemId = i?.Id)"
                                            Placeholder="Stock item (optional)"
                                            DropUp="true" />
                        </div>
                    }
                    <button type="button" class="bo-btn bo-btn-ghost" title="Remove variant"
                            @onclick="@(() => Content.Variants.Remove(row))">✕</button>
                </div>
            }
            <button type="button" class="bo-btn bo-btn-ghost" @onclick="AddVariantRow">+ Add variant</button>
        </div>

        <div class="bo-cmp-field">
            <label class="bo-cmp-field-label">Image</label>
            <div style="display:flex; align-items:center; gap:12px;">
                @if (!string.IsNullOrEmpty(Content.ImagePath))
                {
                    <img src="@Content.ImagePath" alt="preview" style="height:64px; width:64px; object-fit:cover; border-radius:8px; border:1px solid var(--bo-border-soft);" />
                }
                else
                {
                    <span style="color: var(--bo-text-subtle);">No image</span>
                }
                <InputFile OnChange="OnFileSelectedAsync" accept="image/png,image/jpeg,image/webp" disabled="@_uploading" />
                @if (_uploading)
                {
                    <span class="bo-text-subtle">Uploading…</span>
                }
            </div>
            <div class="bo-cmp-field-hint">JPG, PNG or WebP, up to 2 MB.</div>
        </div>
    </div>
</BoDialogBody>

<BoDialogFooter>
    <BoButton Variant="ghost" OnClick="CancelAsync" Disabled="_busy">Cancel</BoButton>
    <BoButton Variant="primary" OnClick="SaveAsync" Loading="_busy" Disabled="_uploading">@(Content.Id is null ? "Create" : "Save")</BoButton>
</BoDialogFooter>

@code {
    [Parameter] public ProductFormModel Content { get; set; } = default!;
    [CascadingParameter] public BoDialogInstance Dialog { get; set; } = default!;

    private string? _error;
    private bool _busy;
    private bool _uploading;
    private List<ProductCategoryDto> _categories = new();
    private List<KitchenStationDto> _stations = new();
    private List<InventoryItemDto> _stockItems = new();

    private ElementReference _root;
    private IJSObjectReference? _flow;
    private bool _codeTouched;

    public record MethodOption(InventoryMethod Value, string Label);
    private readonly List<MethodOption> _methods = new()
    {
        new(InventoryMethod.None, "None (no stock impact)"),
        new(InventoryMethod.DirectStock, "Direct stock (deduct a stock item)"),
        new(InventoryMethod.RecipeBased, "Recipe-based (deduct ingredients)"),
    };

    private ProductCategoryDto? _selectedCategory =>
        _categories.FirstOrDefault(c => c.Id == Content.ProductCategoryId);

    private KitchenStationDto? _selectedStation =>
        _stations.FirstOrDefault(s => s.Id == Content.KitchenStationId);

    private MethodOption? _selectedMethod => _methods.FirstOrDefault(m => m.Value == Content.InventoryMethod);

    protected override async Task OnInitializedAsync()
    {
        _codeTouched = Content.Id is not null; // editing: never auto-rewrite an existing code
        try
        {
            var all = await Mediator.Send(new GetProductCategoriesQuery());
            _categories = all.Where(c => c.IsActive).ToList();
            _stations = (await Mediator.Send(new GetKitchenStationsQuery())).ToList();
            _stockItems = (await Mediator.Send(new GetInventoryItemsQuery(PageSize: 500, IncludeInactive: false))).Items.ToList();

            // Preselect the linked item(s) when editing an existing DirectStock product.
            if (Content.InventoryMethod == InventoryMethod.DirectStock && Content.Id is { } pid)
            {
                if (Content.Variants.Count == 0)
                    Content.LinkedInventoryItemId ??= _stockItems.FirstOrDefault(i => i.ProductId == pid && i.VariantId == null)?.Id;
                else
                    foreach (var row in Content.Variants)
                        row.LinkedInventoryItemId ??= _stockItems.FirstOrDefault(i => i.ProductId == pid && i.VariantId == row.Id)?.Id;
            }
        }
        catch (Exception ex) { _error = $"Failed to load categories: {ex.Message}"; }
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _error = null;
        _uploading = true;
        try
        {
            Content.ImagePath = await ImageUploadService.SaveAsync(e.File);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _uploading = false; }
    }

    private void AddVariantRow() => Content.Variants.Add(new VariantFormRow());

    private void OnCodeChanged(string? value)
    {
        Content.Code = value;
        _codeTouched = true; // user typed in Code — stop auto-filling from Name
    }

    private void OnNameChanged(string? value)
    {
        Content.Name = value;
        // New products only: keep Code in sync with the name until the user edits Code.
        if (Content.Id is null && !_codeTouched)
            Content.Code = Slugify(value);
    }

    /// <summary>"Chicken Biryani" → "CHICKEN-BIRYANI". Upper, alphanumeric runs joined by '-', max 40.</summary>
    private static string Slugify(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return string.Empty;
        var sb = new System.Text.StringBuilder(name.Length);
        var prevDash = false;
        foreach (var ch in name.Trim())
        {
            if (char.IsLetterOrDigit(ch))
            {
                sb.Append(char.ToUpperInvariant(ch));
                prevDash = false;
            }
            else if (!prevDash && sb.Length > 0)
            {
                sb.Append('-');
                prevDash = true;
            }
        }
        var slug = sb.ToString().Trim('-');
        return slug.Length > 40 ? slug[..40].Trim('-') : slug;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _flow = await JS.InvokeAsync<IJSObjectReference>("boEnterFlow.attach", _root);
    }

    public async ValueTask DisposeAsync()
    {
        if (_flow is not null)
        {
            try
            {
                await _flow.InvokeVoidAsync("dispose");
                await _flow.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit gone — nothing to clean up */ }
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(Content.Code)) { _error = "Code is required."; return; }
        if (string.IsNullOrWhiteSpace(Content.Name)) { _error = "Name is required."; return; }
        if (Content.ProductCategoryId == Guid.Empty) { _error = "Category is required."; return; }
        if (Content.Variants.Any(v => string.IsNullOrWhiteSpace(v.Name))) { _error = "Every variant needs a name."; return; }

        // DisplayOrder follows the row order in the editor.
        var variants = Content.Variants
            .Select((v, i) => new ProductVariantInput(v.Id, v.Name.Trim(), v.Price, i + 1))
            .ToList();

        _busy = true;
        try
        {
            if (Content.Id is null)
            {
                var id = await Mediator.Send(new CreateProductCommand(
                    Content.ProductCategoryId,
                    Content.Code.Trim(),
                    Content.Name.Trim(),
                    string.IsNullOrWhiteSpace(Content.BanglaName) ? null : Content.BanglaName.Trim(),
                    Content.Price,
                    string.IsNullOrWhiteSpace(Content.Description) ? null : Content.Description.Trim(),
                    Content.ImagePath,
                    Content.DisplayOrder,
                    variants));
                Content.SavedId = id;
            }
            else
            {
                await Mediator.Send(new UpdateProductCommand(
                    Content.Id.Value,
                    Content.ProductCategoryId,
                    Content.Code.Trim(),
                    Content.Name.Trim(),
                    string.IsNullOrWhiteSpace(Content.BanglaName) ? null : Content.BanglaName.Trim(),
                    Content.Price,
                    string.IsNullOrWhiteSpace(Content.Description) ? null : Content.Description.Trim(),
                    Content.ImagePath,
                    Content.DisplayOrder,
                    variants));
                Content.SavedId = Content.Id;
            }

            if (Content.SavedId is { } productId)
            {
                await Mediator.Send(new AssignProductStationCommand(productId, Content.KitchenStationId));

                // RecipeBased keeps whatever the recipe editor set; here we only need to persist
                // None / DirectStock (DirectStock links each variant — or the product — to its stock item).
                if (Content.InventoryMethod != InventoryMethod.RecipeBased)
                {
                    var links = await BuildStockLinksAsync(productId);
                    await Mediator.Send(new SetProductInventoryMethodCommand(
                        productId, Content.InventoryMethod, links));
                }
            }

            Dialog.Close(Content);
        }
        catch (ValidationException vex)
        {
            _error = vex.Errors.Any()
                ? string.Join("; ", vex.Errors.Select(e => e.ErrorMessage))
                : vex.Message;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    /// <summary>
    /// Builds the per-variant (or product-level) DirectStock links to send to SetProductInventoryMethodCommand.
    /// Null for non-DirectStock (the command then just unlinks + sets the flag). New variants only get their ids
    /// server-side, so for a variant product we re-read the saved product and map form rows by name.
    /// </summary>
    private async Task<List<VariantStockLinkInput>?> BuildStockLinksAsync(Guid productId)
    {
        if (Content.InventoryMethod != InventoryMethod.DirectStock) return null;

        if (Content.Variants.Count == 0)
            return Content.LinkedInventoryItemId is { } itemId
                ? new List<VariantStockLinkInput> { new(null, itemId) }
                : new List<VariantStockLinkInput>();

        var saved = (await Mediator.Send(new GetProductsQuery())).FirstOrDefault(p => p.Id == productId);
        var idByName = new Dictionary<string, Guid>();
        foreach (var v in saved?.Variants ?? Array.Empty<ProductVariantDto>())
            idByName[v.Name.Trim()] = v.Id; // last wins on duplicate names (harmless)

        var links = new List<VariantStockLinkInput>();
        foreach (var row in Content.Variants)
        {
            if (row.LinkedInventoryItemId is not { } itemId) continue; // unlinked variant → no deduction
            if (idByName.TryGetValue(row.Name.Trim(), out var vid))
                links.Add(new VariantStockLinkInput(vid, itemId));
        }
        return links;
    }

    private async Task CancelAsync() => Dialog.Cancel();
}
