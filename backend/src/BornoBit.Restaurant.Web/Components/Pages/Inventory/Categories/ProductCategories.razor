@page "/inventory/categories"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.ProductCategories

<PageTitle>Product Categories · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Product Categories"
                Description="Group products into categories. Display order controls how they sort.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Category</button>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading categories…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_categories.Count == 0)
    {
        <EmptyState Description="No product categories yet. Click '+ New Category' to add one." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted);">Order</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted);">Name</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted);">Description</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); text-align:center;">Status</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _categories)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px; font-family: ui-monospace, monospace; color: var(--bo-text-subtle);">@c.DisplayOrder</td>
                            <td style="padding:10px 14px;"><strong>@c.Name</strong></td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@(c.Description ?? "—")</td>
                            <td style="padding:10px 14px; text-align:center;">
                                <span class="bo-pill @(c.IsActive ? "bo-pill-active" : "bo-pill-inactive")">@(c.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td style="padding:10px 14px; text-align:right;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(c))">Edit</button>
                                @if (c.IsActive)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(c, false))">Deactivate</button>
                                }
                                else
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(c, true))">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
