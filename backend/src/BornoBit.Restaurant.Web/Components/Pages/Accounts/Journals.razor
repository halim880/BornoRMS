@page "/accounts/journals"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Journals
@using BornoBit.Restaurant.Domain.Accounting

<PageTitle>Journal Entries · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Journal Entries"
                Description="Double-entry transactions. Drafts can be edited; posting freezes an entry and updates the ledger.">
        <Actions>
            <a class="bo-btn bo-btn-primary" href="/accounts/journals/new">+ New Entry</a>
        </Actions>
    </PageHeader>

    <div class="bo-card" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
        <BoSelect TOption="StatusOption"
                  Items="@_statusOptions"
                  OptionValue="@(o => o.Key)"
                  OptionText="@(o => o.Label)"
                  SelectedOption="@_selectedStatus"
                  SelectedOptionChanged="OnStatusChanged"
                  Label="Status" Style="width:180px;" />
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading entries…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_items.Count == 0)
    {
        <EmptyState Description="No journal entries match the filter." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Number</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Date</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Type</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Narration</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Amount</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Status</th>
                        <th style="padding:10px 14px; text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in _items)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@e.EntryNumber</span></td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted); white-space:nowrap;">@e.EntryDate.ToString("yyyy-MM-dd")</td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted);">@e.VoucherType</td>
                            <td style="padding:10px 14px;">@(string.IsNullOrEmpty(e.Narration) ? "—" : e.Narration)</td>
                            <td style="padding:10px 14px; text-align:right;">@e.TotalDebit.ToString("0.00")</td>
                            <td style="padding:10px 14px;"><BoBadge Tone="@ToneFor(e.Status)">@e.Status</BoBadge></td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                @if (e.Status == JournalStatus.Draft)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => PostAsync(e))">Post</button>
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => VoidAsync(e))">Void</button>
                                }
                                else if (e.Status == JournalStatus.Posted)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => VoidAsync(e))">Void</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
