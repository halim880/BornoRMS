@page "/accounts/transactions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Categories
@using BornoBit.Restaurant.Application.Accounting.CashAccounts
@using BornoBit.Restaurant.Application.Accounting.Transactions
@using BornoBit.Restaurant.Domain.Accounting

<PageTitle>Transactions · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Transactions"
                Description="Income and expenses. Each entry moves money in or out of a cash account.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Transaction</button>
        </Actions>
    </PageHeader>

    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
        <div class="bo-card" style="flex:1; min-width:180px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Income</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-success, #16a34a);">@_summary.TotalIncome.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:180px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Expense</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-danger, #dc2626);">@_summary.TotalExpense.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:180px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Net</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700;">@_summary.Net.ToString("#,##0.00")</div>
        </div>
    </div>

    <div class="bo-card" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
        <BoSelect TOption="TypeOption"
                  Items="@_typeOptions"
                  OptionValue="@(o => o.Key)"
                  OptionText="@(o => o.Label)"
                  SelectedOption="@_selectedType"
                  SelectedOptionChanged="OnTypeChanged"
                  Label="Type" Style="width:150px;" />
        <BoSelect TOption="CategoryDto"
                  Items="@_categories"
                  OptionValue="@(c => c.Id.ToString())"
                  OptionText="@(c => c.Name)"
                  SelectedOption="@_selectedCategory"
                  SelectedOptionChanged="OnCategoryChanged"
                  Label="Category" Placeholder="(all)" Style="width:180px;" />
        <BoSelect TOption="CashAccountDto"
                  Items="@_accounts"
                  OptionValue="@(a => a.Id.ToString())"
                  OptionText="@(a => a.Name)"
                  SelectedOption="@_selectedAccount"
                  SelectedOptionChanged="OnAccountChanged"
                  Label="Cash account" Placeholder="(all)" Style="width:180px;" />
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading transactions…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_items.Count == 0)
    {
        <EmptyState Description="No transactions match the filter." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Number</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Date</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Type</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Category</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Account</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Amount</th>
                        <th style="padding:10px 14px; text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _items)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@t.Number</span></td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted); white-space:nowrap;">@t.OccurredOn.ToString("yyyy-MM-dd")</td>
                            <td style="padding:10px 14px;">
                                <BoBadge Tone="@(t.Type == TransactionType.Income ? "success" : "warning")">@t.Type</BoBadge>
                            </td>
                            <td style="padding:10px 14px;">@t.CategoryName</td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted);">@t.CashAccountName</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:600;">@t.Amount.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(t))">Edit</button>
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => DeleteAsync(t))">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:12px;">
            <span style="color:var(--bo-text-muted); font-size:var(--bo-font-sm);">
                Page @_page of @Math.Max(1, _totalPages) · @_totalCount total
            </span>
            <div style="display:flex; gap:8px;">
                <button type="button" class="bo-btn bo-btn-ghost" disabled="@(_page <= 1)" @onclick="PrevPageAsync">Previous</button>
                <button type="button" class="bo-btn bo-btn-ghost" disabled="@(_page >= _totalPages)" @onclick="NextPageAsync">Next</button>
            </div>
        </div>
    }
</div>
