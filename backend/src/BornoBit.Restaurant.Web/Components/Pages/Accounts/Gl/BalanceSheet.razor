@page "/accounts/gl/balance-sheet"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>Balance Sheet · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Balance Sheet" Description="Assets vs Liabilities + Equity, as of a date. Current-period profit shown in equity.">
        <Actions>
            <BoButton Variant="ghost" OnClick="PrintAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="Print" Size="16" /> Print</span>
            </BoButton>
        </Actions>
    </PageHeader>

    <div class="bo-card no-print" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_asOf" DateTimeValueChanged="OnAsOfChanged" Label="As of" />
        <div style="margin-left:auto; font-weight:700; color:@(_report.IsBalanced ? "var(--bo-success, #16a34a)" : "var(--bo-danger, #dc2626)");">
            @(_report.IsBalanced ? "✓ Balanced" : "✗ Out of balance")
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading balance sheet…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <div class="bo-card" style="flex:1; min-width:300px; padding:0; overflow:hidden;">
                @Section("Assets", _report.Assets, _report.TotalAssets, null)
            </div>
            <div class="bo-card" style="flex:1; min-width:300px; padding:0; overflow:hidden;">
                @Section("Liabilities", _report.Liabilities, _report.TotalLiabilities, null)
                @Section("Equity", _report.Equity, _report.TotalEquity, _report.CurrentEarnings)
                <table style="width:100%; border-collapse:collapse;">
                    <tbody>
                        <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                            <td style="padding:10px 14px; font-weight:800;">Liabilities + Equity</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:800;">@((_report.TotalLiabilities + _report.TotalEquity).ToString("#,##0.00"))</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    // currentEarnings: when provided (Equity section), appends a "Current earnings" line before the total.
    private RenderFragment Section(string title, IReadOnlyList<GlAccountLineDto> lines, decimal total, decimal? currentEarnings) => __builder =>
    {
        <table style="width:100%; border-collapse:collapse;">
            <tbody>
                <tr style="background:var(--bo-bg-soft);">
                    <th colspan="2" style="padding:10px 14px; text-align:left; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">@title</th>
                </tr>
                @foreach (var l in lines)
                {
                    <tr style="border-top:1px solid var(--bo-border-soft);">
                        <td style="padding:8px 14px;"><span class="bo-code bo-code-slate">@l.Code</span> @l.Name</td>
                        <td style="padding:8px 14px; text-align:right;">@l.Amount.ToString("#,##0.00")</td>
                    </tr>
                }
                @if (currentEarnings is { } ce)
                {
                    <tr style="border-top:1px solid var(--bo-border-soft);">
                        <td style="padding:8px 14px; font-style:italic;">Current earnings</td>
                        <td style="padding:8px 14px; text-align:right; font-style:italic;">@ce.ToString("#,##0.00")</td>
                    </tr>
                }
                <tr style="border-top:1px solid var(--bo-border);">
                    <td style="padding:10px 14px; font-weight:700;">Total @title.ToLowerInvariant()</td>
                    <td style="padding:10px 14px; text-align:right; font-weight:700;">@total.ToString("#,##0.00")</td>
                </tr>
            </tbody>
        </table>
    };
}
