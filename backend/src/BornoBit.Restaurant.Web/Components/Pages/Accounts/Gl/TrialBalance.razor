@page "/accounts/gl/trial-balance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>Trial Balance · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Trial Balance" Description="Posted ledger balances by account. Debits must equal credits.">
        <Actions>
            <BoButton Variant="ghost" OnClick="PrintAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="Print" Size="16" /> Print</span>
            </BoButton>
        </Actions>
    </PageHeader>

    <div class="bo-card no-print" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
        <div style="margin-left:auto; font-weight:700; color:@(_report.IsBalanced ? "var(--bo-success, #16a34a)" : "var(--bo-danger, #dc2626)");">
            @(_report.IsBalanced ? "✓ Balanced" : "✗ Out of balance")
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading trial balance…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_report.Rows.Count == 0)
    {
        <EmptyState Description="No posted journal entries in this period." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Code</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Account</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Debit</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _report.Rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:8px 14px;"><span class="bo-code bo-code-slate">@r.Code</span></td>
                            <td style="padding:8px 14px;">@r.Name</td>
                            <td style="padding:8px 14px; text-align:right;">@(r.Debit > 0m ? r.Debit.ToString("#,##0.00") : "—")</td>
                            <td style="padding:8px 14px; text-align:right;">@(r.Credit > 0m ? r.Credit.ToString("#,##0.00") : "—")</td>
                        </tr>
                    }
                    <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                        <td style="padding:10px 14px; font-weight:700;" colspan="2">Total</td>
                        <td style="padding:10px 14px; text-align:right; font-weight:700;">@_report.TotalDebit.ToString("#,##0.00")</td>
                        <td style="padding:10px 14px; text-align:right; font-weight:700;">@_report.TotalCredit.ToString("#,##0.00")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
