@page "/accounts/payroll/runs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.CashAccounts
@using BornoBit.Restaurant.Application.Accounting.Payroll
@using BornoBit.Restaurant.Domain.Payroll
@using FluentValidation
@using MediatR
@inject ISender Mediator
@inject BornoBit.Restaurant.Web.Components.BornoUi.Toast.IBoToastService ToastService

<PageTitle>Payroll Runs · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Payroll Runs"
                Description="Monthly payroll. Approve posts the accrual (Salary/Overtime → Employee Payable); Pay settles it against cash." />

    @if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }

    <div class="bo-card" style="padding:16px; margin-bottom:16px; display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap;">
        <BoNumberInput T="int" @bind-Value="_year" Label="Year" Min="2000" Max="9999" Style="width:110px;" />
        <BoNumberInput T="int" @bind-Value="_month" Label="Month" Min="1" Max="12" Style="width:90px;" />
        <BoButton Variant="primary" OnClick="CreateRunAsync" Loading="_busy">Create run</BoButton>
    </div>

    <div style="display:flex; gap:16px; align-items:flex-start; flex-wrap:wrap;">
        <div class="bo-card" style="padding:0; overflow:hidden; min-width:320px; flex:1;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Run</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Status</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Net</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _runs)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft); cursor:pointer; background:@(_run?.Id == r.Id ? "var(--bo-bg-soft)" : "transparent");" @onclick="@(() => SelectAsync(r.Id))">
                            <td style="padding:10px 14px; font-weight:600;">@r.RunNumber<div style="font-size:var(--bo-font-xs); color:var(--bo-text-muted);">@r.Year-@r.Month.ToString("00")</div></td>
                            <td style="padding:10px 14px;">@r.Status</td>
                            <td style="padding:10px 14px; text-align:right;">@r.TotalNet.ToString("#,##0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_run is not null)
        {
            <div class="bo-card" style="padding:16px; flex:2; min-width:420px;">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                    <strong style="font-size:var(--bo-font-md);">@_run.RunNumber · @_run.Year-@_run.Month.ToString("00")</strong>
                    <span style="color:var(--bo-text-muted);">@_run.Status</span>
                    <div style="margin-left:auto; display:flex; gap:8px; align-items:flex-end;">
                        @if (_run.Status == PayrollRunStatus.Draft)
                        {
                            <BoButton Variant="primary" Size="sm" OnClick="ApproveAsync" Loading="_busy">Approve</BoButton>
                        }
                        else if (_run.Status == PayrollRunStatus.Approved)
                        {
                            <BoSelect TOption="CashAccountDto"
                                      Items="@_accounts"
                                      OptionValue="@(a => a.Id.ToString())"
                                      OptionText="@(a => a.Name)"
                                      SelectedOption="@_accounts.FirstOrDefault(a => a.Id == _payAccountId)"
                                      SelectedOptionChanged="@(a => _payAccountId = a?.Id)"
                                      Placeholder="(pay from)" Style="width:160px;" />
                            <BoButton Variant="primary" Size="sm" OnClick="PayAsync" Loading="_busy">Pay</BoButton>
                        }
                    </div>
                </div>

                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Employee</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Gross</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Overtime</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Deductions</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Net</th>
                            <th style="padding:8px 12px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _run.Lines)
                        {
                            var edit = _edits[l.EmployeeId];
                            <tr style="border-top:1px solid var(--bo-border-soft);">
                                <td style="padding:8px 12px;">@l.EmployeeName</td>
                                @if (_run.Status == PayrollRunStatus.Draft)
                                {
                                    <td style="padding:6px 8px; text-align:right;"><BoNumberInput T="decimal" @bind-Value="edit.Gross" Min="0" Step="0.01" Style="width:100px;" /></td>
                                    <td style="padding:6px 8px; text-align:right;"><BoNumberInput T="decimal" @bind-Value="edit.Overtime" Min="0" Step="0.01" Style="width:90px;" /></td>
                                    <td style="padding:6px 8px; text-align:right;"><BoNumberInput T="decimal" @bind-Value="edit.Deductions" Min="0" Step="0.01" Style="width:90px;" /></td>
                                    <td style="padding:8px 12px; text-align:right; font-weight:600;">@((edit.Gross + edit.Overtime - edit.Deductions).ToString("#,##0.00"))</td>
                                    <td style="padding:6px 8px; text-align:right;"><BoButton Variant="ghost" Size="sm" OnClick="@(() => SaveLineAsync(l.EmployeeId))">Save</BoButton></td>
                                }
                                else
                                {
                                    <td style="padding:8px 12px; text-align:right;">@l.Gross.ToString("#,##0.00")</td>
                                    <td style="padding:8px 12px; text-align:right;">@l.Overtime.ToString("#,##0.00")</td>
                                    <td style="padding:8px 12px; text-align:right;">@l.Deductions.ToString("#,##0.00")</td>
                                    <td style="padding:8px 12px; text-align:right; font-weight:600;">@l.Net.ToString("#,##0.00")</td>
                                    <td></td>
                                }
                            </tr>
                        }
                        <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                            <td style="padding:8px 12px; font-weight:700;">Total</td>
                            <td style="padding:8px 12px; text-align:right; font-weight:700;">@_run.TotalGross.ToString("#,##0.00")</td>
                            <td style="padding:8px 12px; text-align:right; font-weight:700;">@_run.TotalOvertime.ToString("#,##0.00")</td>
                            <td style="padding:8px 12px; text-align:right; font-weight:700;">@_run.TotalDeductions.ToString("#,##0.00")</td>
                            <td style="padding:8px 12px; text-align:right; font-weight:700;">@_run.TotalNet.ToString("#,##0.00")</td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool _busy;
    private string? _error;
    private List<PayrollRunSummaryDto> _runs = new();
    private List<CashAccountDto> _accounts = new();
    private PayrollRunDto? _run;
    private Guid? _payAccountId;

    private int _year = DateTime.UtcNow.Year;
    private int _month = DateTime.UtcNow.Month;

    private sealed class LineEdit { public decimal Gross; public decimal Overtime; public decimal Deductions; }
    private Dictionary<Guid, LineEdit> _edits = new();

    protected override async Task OnInitializedAsync()
    {
        _accounts = (await Mediator.Send(new GetCashAccountsQuery(ActiveOnly: true))).ToList();
        await ReloadRunsAsync();
    }

    private async Task ReloadRunsAsync()
    {
        _error = null;
        try { _runs = (await Mediator.Send(new GetPayrollRunsQuery())).ToList(); }
        catch (Exception ex) { _error = $"Failed to load runs: {ex.Message}"; }
    }

    private async Task SelectAsync(Guid id)
    {
        _error = null;
        try
        {
            _run = await Mediator.Send(new GetPayrollRunQuery(id));
            _edits = _run.Lines.ToDictionary(l => l.EmployeeId, l => new LineEdit { Gross = l.Gross, Overtime = l.Overtime, Deductions = l.Deductions });
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task CreateRunAsync()
    {
        _busy = true; _error = null;
        try
        {
            var id = await Mediator.Send(new CreatePayrollRunCommand(_year, _month));
            ToastService.ShowSuccess("Payroll run created.");
            await ReloadRunsAsync();
            await SelectAsync(id);
        }
        catch (ValidationException vex) { _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage)); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task SaveLineAsync(Guid employeeId)
    {
        if (_run is null) return;
        _error = null;
        var edit = _edits[employeeId];
        try
        {
            await Mediator.Send(new UpdatePayrollLineCommand(_run.Id, employeeId, edit.Gross, edit.Overtime, edit.Deductions));
            await SelectAsync(_run.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ApproveAsync()
    {
        if (_run is null) return;
        _busy = true; _error = null;
        try
        {
            await Mediator.Send(new ApprovePayrollRunCommand(_run.Id));
            ToastService.ShowSuccess("Payroll run approved (accrual posted).");
            await ReloadRunsAsync();
            await SelectAsync(_run.Id);
        }
        catch (ValidationException vex) { _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage)); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task PayAsync()
    {
        if (_run is null) return;
        if (_payAccountId is null) { _error = "Select a cash account to pay from."; return; }
        _busy = true; _error = null;
        try
        {
            await Mediator.Send(new PayPayrollRunCommand(_run.Id, _payAccountId.Value));
            ToastService.ShowSuccess("Payroll paid.");
            await ReloadRunsAsync();
            await SelectAsync(_run.Id);
        }
        catch (ValidationException vex) { _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage)); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
