@page "/accounts/categories"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Categories
@using BornoBit.Restaurant.Domain.Accounting

<PageTitle>Categories · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Categories"
                Description="Buckets that income and expense transactions are filed under.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Category</button>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading categories…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_categories.Count == 0)
    {
        <EmptyState Description="No categories yet." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Name</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Type</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Status</th>
                        <th style="padding:10px 14px; text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _categories)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px; font-weight:600;">@c.Name</td>
                            <td style="padding:10px 14px;">
                                <BoBadge Tone="@(c.Type == TransactionType.Income ? "success" : "warning")">@c.Type</BoBadge>
                            </td>
                            <td style="padding:10px 14px;">
                                <span class="bo-pill @(c.IsActive ? "bo-pill-active" : "bo-pill-inactive")">@(c.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(c))">Edit</button>
                                @if (c.IsActive)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(c, false))">Deactivate</button>
                                }
                                else
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(c, true))">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
