@page "/accounts/payables"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Inventory.Payables

<PageTitle>Supplier Payables · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Supplier Payables"
                Description="What each supplier is owed — goods received minus payments made. Record a payment to book the purchase cost." />

    <div class="bo-card" style="padding:12px; margin-bottom:16px; display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
        <BoCheckbox Value="_outstandingOnly" ValueChanged="OnOutstandingOnlyChanged" Label="Outstanding only" />
        <div style="margin-left:auto; font-size:var(--bo-font-sm); color:var(--bo-text-muted);">
            Total outstanding: <strong style="color:var(--bo-danger, #dc2626);">@TotalOutstanding.ToString("#,##0.00")</strong>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading payables…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_payables.Count == 0)
    {
        <EmptyState Description="No supplier balances to show." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Supplier</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Received</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Paid</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Outstanding</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Terms</th>
                        <th style="padding:10px 14px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _payables)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;">
                                <div style="font-weight:600;">@p.SupplierName</div>
                                <div style="font-size:var(--bo-font-xs); color:var(--bo-text-muted);">@p.SupplierCode</div>
                            </td>
                            <td style="padding:10px 14px; text-align:right;">@p.Received.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; color:var(--bo-success, #16a34a);">@p.Paid.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:700; color:@(p.Outstanding > 0m ? "var(--bo-danger, #dc2626)" : "inherit");">@p.Outstanding.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; color:var(--bo-text-muted);">@(p.PaymentTermsDays > 0 ? $"{p.PaymentTermsDays}d" : "—")</td>
                            <td style="padding:10px 14px; text-align:right;">
                                <BoButton Variant="ghost" Size="sm" OnClick="@(() => PayAsync(p))">Pay</BoButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_recent.Count > 0)
        {
            <h3 style="margin:24px 0 8px; font-size:var(--bo-font-md);">Recent payments</h3>
            <div class="bo-card" style="padding:0; overflow:hidden;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Date</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Supplier</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Account</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Reference</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _recent)
                        {
                            <tr style="border-top:1px solid var(--bo-border-soft);">
                                <td style="padding:10px 14px; color:var(--bo-text-muted); white-space:nowrap;">@r.PaidOn.ToString("yyyy-MM-dd")</td>
                                <td style="padding:10px 14px;">@r.SupplierName</td>
                                <td style="padding:10px 14px; color:var(--bo-text-muted);">@(r.CashAccountName ?? "—")</td>
                                <td style="padding:10px 14px; color:var(--bo-text-muted);">@(r.Reference ?? "—")</td>
                                <td style="padding:10px 14px; text-align:right; font-weight:600;">@r.Amount.ToString("#,##0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>
