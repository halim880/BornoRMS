@page "/accounts/ledger"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Accounts
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>Ledger · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Account Ledger"
                Description="Posted activity for one account, with opening balance and a running balance on its natural side." />

    <div class="bo-card" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoSelect TOption="AccountDto"
                  Items="@_accounts"
                  OptionValue="@(a => a.Id.ToString())"
                  OptionText="@(a => a.Code + " · " + a.Name)"
                  SelectedOption="@_selectedAccount"
                  SelectedOptionChanged="OnAccountChanged"
                  Label="Account" Placeholder="Select an account" Style="min-width:280px;" />
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
    </div>

    @if (_selectedAccount is null)
    {
        <EmptyState Description="Select an account to view its ledger." />
    }
    else if (_loading)
    {
        <LoadingState Message="Loading ledger…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_report is not null)
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Date</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Entry</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Narration</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Debit</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Credit</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-top:1px solid var(--bo-border-soft); color:var(--bo-text-muted);">
                        <td colspan="5" style="padding:10px 14px; font-style:italic;">Opening balance</td>
                        <td style="padding:10px 14px; text-align:right; font-weight:600;">@_report.OpeningBalance.ToString("0.00")</td>
                    </tr>
                    @foreach (var r in _report.Rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px; color:var(--bo-text-muted); white-space:nowrap;">@r.EntryDate.ToString("yyyy-MM-dd")</td>
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@r.EntryNumber</span></td>
                            <td style="padding:10px 14px;">@(string.IsNullOrEmpty(r.Narration) ? "—" : r.Narration)</td>
                            <td style="padding:10px 14px; text-align:right;">@(r.Debit == 0m ? "" : r.Debit.ToString("0.00"))</td>
                            <td style="padding:10px 14px; text-align:right;">@(r.Credit == 0m ? "" : r.Credit.ToString("0.00"))</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:600;">@r.RunningBalance.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="border-top:2px solid var(--bo-border-soft); font-weight:700;">
                        <td colspan="5" style="padding:10px 14px; text-align:right;">Closing balance</td>
                        <td style="padding:10px 14px; text-align:right;">@_report.ClosingBalance.ToString("0.00")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@code {
    [Inject] private MediatR.ISender Mediator { get; set; } = default!;

    private bool _loading;
    private string? _error;
    private List<AccountDto> _accounts = new();
    private AccountDto? _selectedAccount;
    private AccountLedgerDto? _report;
    private DateTime? _from;
    private DateTime? _to;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _accounts = (await Mediator.Send(new GetAccountsQuery(PostableOnly: true))).ToList();
        }
        catch (Exception ex) { _error = $"Failed to load accounts: {ex.Message}"; }
    }

    private Task OnAccountChanged(AccountDto? a) { _selectedAccount = a; return ReloadAsync(); }
    private Task OnFromChanged(DateTime? d) { _from = d; return ReloadAsync(); }
    private Task OnToChanged(DateTime? d) { _to = d; return ReloadAsync(); }

    private async Task ReloadAsync()
    {
        if (_selectedAccount is null) { _report = null; return; }
        _loading = true; _error = null;
        try
        {
            _report = await Mediator.Send(new GetAccountLedgerQuery(_selectedAccount.Id, _from, _to));
        }
        catch (Exception ex) { _error = $"Failed to load ledger: {ex.Message}"; }
        finally { _loading = false; }
    }
}
