@page "/accounts/trial-balance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>Trial Balance · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Trial Balance"
                Description="Net balance of every account over posted entries. A healthy ledger has equal column totals." />

    <div class="bo-card" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
    </div>

    @if (_loading)
    {
        <LoadingState Message="Computing trial balance…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_report is null || _report.Rows.Count == 0)
    {
        <EmptyState Description="No posted entries in this period." />
    }
    else
    {
        @if (!_report.IsBalanced)
        {
            <BoMessageBar Intent="warning">Trial balance does not tie out — debits and credits differ. Check for data issues.</BoMessageBar>
        }
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Code</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Account</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Type</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Debit</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _report.Rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@r.Code</span></td>
                            <td style="padding:10px 14px;">@r.Name</td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted);">@r.AccountType</td>
                            <td style="padding:10px 14px; text-align:right;">@(r.Debit == 0m ? "" : r.Debit.ToString("0.00"))</td>
                            <td style="padding:10px 14px; text-align:right;">@(r.Credit == 0m ? "" : r.Credit.ToString("0.00"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="border-top:2px solid var(--bo-border-soft); font-weight:700;">
                        <td colspan="3" style="padding:10px 14px; text-align:right;">Totals</td>
                        <td style="padding:10px 14px; text-align:right;">@_report.TotalDebit.ToString("0.00")</td>
                        <td style="padding:10px 14px; text-align:right;">@_report.TotalCredit.ToString("0.00")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>

@code {
    [Inject] private MediatR.ISender Mediator { get; set; } = default!;

    private bool _loading = true;
    private string? _error;
    private TrialBalanceDto? _report;
    private DateTime? _from;
    private DateTime? _to;

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true; _error = null;
        try
        {
            _report = await Mediator.Send(new GetTrialBalanceQuery(_from, _to));
        }
        catch (Exception ex) { _error = $"Failed to compute trial balance: {ex.Message}"; }
        finally { _loading = false; }
    }

    private Task OnFromChanged(DateTime? d) { _from = d; return ReloadAsync(); }
    private Task OnToChanged(DateTime? d) { _to = d; return ReloadAsync(); }
}
