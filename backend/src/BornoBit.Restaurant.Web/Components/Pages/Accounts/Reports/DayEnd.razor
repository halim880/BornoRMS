@page "/accounts/reports/day-end"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports
@using BornoBit.Restaurant.Domain.Accounting

<PageTitle>Day-End Close · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Day-End Close"
                Description="Reconcile one business day: sales, collections by method, drawer counts, expenses and un-imported takings.">
        <Actions>
            <BoButton Variant="ghost" OnClick="PrintAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="Print" Size="16" /> Print</span>
            </BoButton>
        </Actions>
    </PageHeader>

    <div class="bo-card no-print" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_date" DateTimeValueChanged="OnDateChanged" Label="Business day" />
    </div>

    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
        <div class="bo-card" style="flex:1; min-width:150px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Orders</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700;">@_report.OrderCount</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:150px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Sales</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700;">@_report.SalesTotal.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:150px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Collected</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-success, #16a34a);">@_report.TotalCollected.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:150px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Expenses</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-danger, #dc2626);">@_report.TotalExpenses.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:150px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Drawer variance</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:@(_report.DrawerVariance == 0m ? "inherit" : "var(--bo-danger, #dc2626)");">@_report.DrawerVariance.ToString("#,##0.00")</div>
        </div>
    </div>

    @if (_report.UnaccountedOrders > 0)
    {
        <BoMessageBar Intent="warning">
            @_report.UnaccountedOrders order(s) totalling @_report.UnaccountedAmount.ToString("#,##0.00") @_report.Currency are not yet imported into the books. Run the Cash Counter import.
        </BoMessageBar>
    }

    @if (_loading)
    {
        <LoadingState Message="Loading day-end…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:16px;">
            <div class="bo-card" style="flex:1; min-width:280px; padding:0; overflow:hidden;">
                <div style="padding:10px 14px; font-weight:700; border-bottom:1px solid var(--bo-border-soft);">Collections by method</div>
                @if (_report.ByMethod.Count == 0)
                {
                    <div style="padding:14px; color:var(--bo-text-muted);"><em>No payments.</em></div>
                }
                else
                {
                    <table style="width:100%; border-collapse:collapse;">
                        <tbody>
                            @foreach (var m in _report.ByMethod)
                            {
                                <tr style="border-top:1px solid var(--bo-border-soft);">
                                    <td style="padding:10px 14px;">@m.Method</td>
                                    <td style="padding:10px 14px; text-align:right; color:var(--bo-text-muted);">@m.Count</td>
                                    <td style="padding:10px 14px; text-align:right; font-weight:600;">@m.Amount.ToString("#,##0.00")</td>
                                </tr>
                            }
                            <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                                <td style="padding:10px 14px; font-weight:700;" colspan="2">Total</td>
                                <td style="padding:10px 14px; text-align:right; font-weight:700; color:var(--bo-success, #16a34a);">@_report.TotalCollected.ToString("#,##0.00")</td>
                            </tr>
                        </tbody>
                    </table>
                }
            </div>

            <div class="bo-card" style="flex:1; min-width:280px; padding:0; overflow:hidden;">
                <div style="padding:10px 14px; font-weight:700; border-bottom:1px solid var(--bo-border-soft);">Expenses</div>
                @if (_report.Expenses.Count == 0)
                {
                    <div style="padding:14px; color:var(--bo-text-muted);"><em>No expenses booked.</em></div>
                }
                else
                {
                    <table style="width:100%; border-collapse:collapse;">
                        <tbody>
                            @foreach (var e in _report.Expenses)
                            {
                                <tr style="border-top:1px solid var(--bo-border-soft);">
                                    <td style="padding:10px 14px;">@e.CategoryName</td>
                                    <td style="padding:10px 14px; text-align:right; font-weight:600; color:var(--bo-danger, #dc2626);">@e.Amount.ToString("#,##0.00")</td>
                                </tr>
                            }
                            <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                                <td style="padding:10px 14px; font-weight:700;">Total</td>
                                <td style="padding:10px 14px; text-align:right; font-weight:700;">@_report.TotalExpenses.ToString("#,##0.00")</td>
                            </tr>
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="bo-card" style="margin-top:16px; padding:0; overflow:hidden;">
            <div style="padding:10px 14px; font-weight:700; border-bottom:1px solid var(--bo-border-soft);">Drawer shifts</div>
            @if (_report.Drawers.Count == 0)
            {
                <div style="padding:14px; color:var(--bo-text-muted);"><em>No drawer shifts opened on this day.</em></div>
            }
            else
            {
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Drawer</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Cashier</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Status</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Expected</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Counted</th>
                            <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Variance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in _report.Drawers)
                        {
                            <tr style="border-top:1px solid var(--bo-border-soft);">
                                <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@d.DrawerNumber</span></td>
                                <td style="padding:10px 14px;">@d.CashierName</td>
                                <td style="padding:10px 14px; color:var(--bo-text-muted);">@d.Status</td>
                                <td style="padding:10px 14px; text-align:right;">@d.ExpectedClosingBalance.ToString("#,##0.00")</td>
                                <td style="padding:10px 14px; text-align:right;">@(d.CountedClosingBalance.HasValue ? d.CountedClosingBalance.Value.ToString("#,##0.00") : "—")</td>
                                <td style="padding:10px 14px; text-align:right; font-weight:600; color:@(d.Status == DrawerStatus.Closed && d.Variance != 0m ? "var(--bo-danger, #dc2626)" : "inherit");">@(d.Status == DrawerStatus.Closed ? d.Variance.ToString("#,##0.00") : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>
