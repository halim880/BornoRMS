@page "/accounts/reports/profit-loss"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>Profit &amp; Loss · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Profit & Loss"
                Description="Revenue, cost of goods sold and operating expenses over a period — net profit at the bottom.">
        <Actions>
            <BoButton Variant="ghost" OnClick="PrintAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="Print" Size="16" /> Print</span>
            </BoButton>
        </Actions>
    </PageHeader>

    <div class="bo-card no-print" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
    </div>

    @if (_rangeError is not null)
    {
        <BoMessageBar Intent="warning">@_rangeError</BoMessageBar>
    }

    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
        <div class="bo-card" style="flex:1; min-width:160px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Revenue</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-success, #16a34a);">@_report.TotalRevenue.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:160px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Gross profit</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700;">@_report.GrossProfit.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:160px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Expenses</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-danger, #dc2626);">@((_report.TotalCogs + _report.TotalExpenses).ToString("#,##0.00"))</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:160px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Net profit</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:@(_report.NetProfit >= 0m ? "var(--bo-success, #16a34a)" : "var(--bo-danger, #dc2626)");">@_report.NetProfit.ToString("#,##0.00")</div>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading profit & loss…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <tbody>
                    @RenderSection("Revenue", _report.Revenue, _report.TotalRevenue, isCredit: true)

                    @if (_report.Cogs.Count > 0)
                    {
                        @RenderSection("Cost of goods sold", _report.Cogs, _report.TotalCogs, isCredit: false)
                        @RenderTotalRow("Gross profit", _report.GrossProfit, strong: true)
                    }

                    @RenderSection("Operating expenses", _report.Expenses, _report.TotalExpenses, isCredit: false)

                    <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                        <td style="padding:12px 14px; font-weight:800; font-size:var(--bo-font-md);">Net profit</td>
                        <td style="padding:12px 14px; text-align:right; font-weight:800; font-size:var(--bo-font-md); color:@(_report.NetProfit >= 0m ? "var(--bo-success, #16a34a)" : "var(--bo-danger, #dc2626)");">@_report.NetProfit.ToString("#,##0.00")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private RenderFragment RenderSection(string title, IReadOnlyList<PlLineDto> lines, decimal total, bool isCredit) => __builder =>
    {
        <tr style="background:var(--bo-bg-soft);">
            <th colspan="2" style="padding:10px 14px; text-align:left; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">@title</th>
        </tr>
        @if (lines.Count == 0)
        {
            <tr style="border-top:1px solid var(--bo-border-soft);">
                <td style="padding:10px 14px; color:var(--bo-text-muted);" colspan="2"><em>None</em></td>
            </tr>
        }
        else
        {
            @foreach (var l in lines)
            {
                <tr style="border-top:1px solid var(--bo-border-soft);">
                    <td style="padding:10px 14px;">@l.CategoryName</td>
                    <td style="padding:10px 14px; text-align:right; color:@(isCredit ? "var(--bo-success, #16a34a)" : "var(--bo-danger, #dc2626)");">@l.Amount.ToString("#,##0.00")</td>
                </tr>
            }
        }
        <tr style="border-top:1px solid var(--bo-border);">
            <td style="padding:10px 14px; font-weight:700;">Total @title.ToLowerInvariant()</td>
            <td style="padding:10px 14px; text-align:right; font-weight:700;">@total.ToString("#,##0.00")</td>
        </tr>
    };

    private RenderFragment RenderTotalRow(string title, decimal amount, bool strong) => __builder =>
    {
        <tr style="border-top:1px solid var(--bo-border); background:var(--bo-bg-soft);">
            <td style="padding:10px 14px; font-weight:@(strong ? "700" : "600");">@title</td>
            <td style="padding:10px 14px; text-align:right; font-weight:@(strong ? "700" : "600");">@amount.ToString("#,##0.00")</td>
        </tr>
    };
}
