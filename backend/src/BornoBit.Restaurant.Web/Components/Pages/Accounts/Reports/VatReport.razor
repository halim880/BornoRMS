@page "/accounts/reports/vat"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.Reports

<PageTitle>VAT Report · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="VAT Report"
                Description="Output VAT collected over a period, grouped by rate. Built from per-line tax at settlement.">
        <Actions>
            <BoButton Variant="ghost" OnClick="PrintAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="Print" Size="16" /> Print</span>
            </BoButton>
        </Actions>
    </PageHeader>

    <div class="bo-card no-print" style="padding:12px; margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;">
        <BoDatePicker DateTimeValue="_from" DateTimeValueChanged="OnFromChanged" Label="From" />
        <BoDatePicker DateTimeValue="_to" DateTimeValueChanged="OnToChanged" Label="To" />
    </div>

    @if (_rangeError is not null)
    {
        <BoMessageBar Intent="warning">@_rangeError</BoMessageBar>
    }

    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px;">
        <div class="bo-card" style="flex:1; min-width:180px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Taxable sales</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700;">@_report.TotalTaxable.ToString("#,##0.00")</div>
        </div>
        <div class="bo-card" style="flex:1; min-width:180px;">
            <div style="font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Output VAT</div>
            <div style="font-size:var(--bo-font-xl); font-weight:700; color:var(--bo-primary);">@_report.TotalVat.ToString("#,##0.00")</div>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading VAT report…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_report.Rows.Count == 0)
    {
        <EmptyState Description="No paid sales in this period." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">VAT rate</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Taxable sales</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">VAT</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _report.Rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;">@r.RatePercent.ToString("0.##")%</td>
                            <td style="padding:10px 14px; text-align:right;">@r.TaxableSales.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:600;">@r.Vat.ToString("#,##0.00")</td>
                        </tr>
                    }
                    <tr style="border-top:2px solid var(--bo-border); background:var(--bo-bg-soft);">
                        <td style="padding:10px 14px; font-weight:700;">Total</td>
                        <td style="padding:10px 14px; text-align:right; font-weight:700;">@_report.TotalTaxable.ToString("#,##0.00")</td>
                        <td style="padding:10px 14px; text-align:right; font-weight:700; color:var(--bo-primary);">@_report.TotalVat.ToString("#,##0.00")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
