@page "/accounts/cash-accounts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Accounting.CashAccounts
@using BornoBit.Restaurant.Domain.Accounting

<PageTitle>Cash Accounts · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Cash Accounts"
                Description="Where money sits — cash drawer, mobile wallets, bank. Balance = opening balance plus income minus expenses.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Account</button>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading accounts…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_accounts.Count == 0)
    {
        <EmptyState Description="No cash accounts yet." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Name</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Kind</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Opening</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Balance</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Status</th>
                        <th style="padding:10px 14px; text-align:right;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _accounts)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px; font-weight:600;">@a.Name</td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted);">@KindLabel(a.Kind)</td>
                            <td style="padding:10px 14px; text-align:right; color:var(--bo-text-muted);">@a.OpeningBalance.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:600;">@a.Balance.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px;">
                                <span class="bo-pill @(a.IsActive ? "bo-pill-active" : "bo-pill-inactive")">@(a.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(a))">Edit</button>
                                @if (a.IsActive)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(a, false))">Deactivate</button>
                                }
                                else
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(a, true))">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private static string KindLabel(CashAccountKind kind) => kind switch
    {
        CashAccountKind.Cash => "Cash",
        CashAccountKind.MobileWallet => "Mobile wallet",
        CashAccountKind.Bank => "Bank",
        _ => kind.ToString()
    };
}
