@page "/operations/menu"
@attribute [Authorize(Policy = "Staff")]
@using Microsoft.AspNetCore.Authorization
@using BornoBit.Restaurant.Application.ProductCategories
@using BornoBit.Restaurant.Application.Products
@rendermode InteractiveServer

<PageTitle>Menu · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Menu"
                Description="Today's menu board. Toggle items available or unavailable during service — edit products in Inventory → Products.">
        <Actions>
            <BoButton Variant="ghost" OnClick="ReloadAsync">↻ Refresh</BoButton>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading menu…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_products.Count == 0)
    {
        <EmptyState Description="No products yet. Add them from Inventory → Products." />
    }
    else
    {
        <div class="menu-toolbar">
            <div class="menu-search">
                <BoSearch @bind-Value="_search" Placeholder="Search by name, code or বাংলা নাম…" DebounceMs="150" />
            </div>
            <label class="menu-filter">
                <input type="checkbox" @bind="_unavailableOnly" />
                Unavailable only
            </label>
        </div>

        @if (!Filtered.Any())
        {
            <BoCard>
                <EmptyState Icon="Search" Title="No matching items"
                            Description="Try a different search or clear the filter." />
            </BoCard>
        }
        else
        {
            @foreach (var cat in _categories)
            {
                var items = Filtered.Where(p => p.ProductCategoryId == cat.Id).ToList();
                if (items.Count == 0) { continue; }
                <div class="menu-section">
                    <div class="menu-section-title">
                        @cat.Name
                        <span class="menu-section-count">@items.Count(i => i.IsActive)/@items.Count available</span>
                    </div>
                    <div class="menu-grid">
                        @foreach (var item in items)
                        {
                            <div @key="item.Id" class="menu-card @(item.IsActive ? null : "menu-card--off")">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img class="menu-img" src="@item.ImagePath" alt="@item.Name" loading="lazy" />
                                }
                                else
                                {
                                    <span class="menu-img menu-img--initial">@char.ToUpperInvariant(item.Name[0])</span>
                                }
                                <span class="menu-name">@item.Name</span>
                                @if (!string.IsNullOrEmpty(item.BanglaName))
                                {
                                    <span class="menu-bn">@item.BanglaName</span>
                                }
                                <span class="menu-price">
                                    @(item.HasVariants
                                        ? $"from {item.Currency} {item.MinPrice:0.##}"
                                        : $"{item.Currency} {item.Price:0.##}")
                                </span>
                                <div class="menu-card-foot">
                                    <span class="bo-pill @(item.IsActive ? "bo-pill-active" : "bo-pill-inactive")">
                                        @(item.IsActive ? "Available" : "Unavailable")
                                    </span>
                                    <button type="button" class="bo-btn bo-btn-ghost menu-toggle"
                                            disabled="@(_busyId == item.Id)"
                                            @onclick="() => ToggleAsync(item)">
                                        @(item.IsActive ? "Mark unavailable" : "Mark available")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
</div>
