@page "/operations/cash-counter"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Staff")]
@using BornoBit.Restaurant.Application.Ordering.Queries
@using BornoBit.Restaurant.Domain.Ordering

<PageTitle>Cash Counter · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Cash Counter"
                Description="Settle orders awaiting payment, reprint receipts, and track today's takings.">
        <Actions>
            <BoButton Variant="ghost" OnClick="ReloadAsync">
                <span style="display:inline-flex; align-items:center; gap:6px;"><BoIcon Name="ArrowClockwise" Size="16" /> Refresh</span>
            </BoButton>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading cash counter…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        @* Shift summary strip *@
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:22px;">
            @foreach (var line in _summary!.ByMethod)
            {
                var tint = MethodTint(line.Method);
                <div class="bo-panel report-stat">
                    <span class="report-stat-icon" style="background:@tint.Bg; color:@tint.Color;"><BoIcon Name="@MethodIcon(line.Method)" Size="22" /></span>
                    <span class="report-stat-body">
                        <span class="report-stat-label">@line.Method</span>
                        <span class="report-stat-value">@_summary.Currency @line.Amount.ToString("0.##")</span>
                        <span class="cc-stat-sub">@line.Count order@(line.Count == 1 ? "" : "s")</span>
                    </span>
                </div>
            }
            <div class="bo-panel report-stat" style="border-color:var(--bo-primary);">
                <span class="report-stat-icon" style="background:var(--bo-primary-tint); color:var(--bo-primary);"><BoIcon Name="Wallet" Size="22" /></span>
                <span class="report-stat-body">
                    <span class="report-stat-label">Collected today</span>
                    <span class="report-stat-value" style="color:var(--bo-primary);">@_summary.Currency @_summary.TotalCollected.ToString("0.##")</span>
                    <span class="cc-stat-sub">@_summary.TotalCount order@(_summary.TotalCount == 1 ? "" : "s")</span>
                </span>
            </div>
        </div>

        @* Pending-payment queue *@
        <div class="cc-section">
            <BoIcon Name="ReceiptMoney" Size="18" />
            <span>Awaiting payment</span>
            <BoBadge Tone="@(_pending.Count == 0 ? "neutral" : "warning")">@_pending.Count</BoBadge>
        </div>
        @if (_pending.Count == 0)
        {
            <EmptyState Icon="Checkmark" Description="No orders awaiting payment. All settled!" />
        }
        else
        {
            <div class="bo-panel" style="padding:0; overflow:hidden; margin-bottom:8px;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th class="cc-th">Order #</th>
                            <th class="cc-th">Type / Table</th>
                            <th class="cc-th">Customer</th>
                            <th class="cc-th" style="text-align:right;">Items</th>
                            <th class="cc-th" style="text-align:right;">Grand total</th>
                            <th class="cc-th">Status</th>
                            <th class="cc-th" style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _pending)
                        {
                            <tr class="cc-row">
                                <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@o.OrderNumber</span></td>
                                <td style="padding:10px 14px;">
                                    @o.OrderType
                                    @if (!string.IsNullOrEmpty(o.TableNumber))
                                    {
                                        <span style="color: var(--bo-text-muted);"> · Table @o.TableNumber</span>
                                    }
                                </td>
                                <td style="padding:10px 14px;">
                                    <strong>@(string.IsNullOrEmpty(o.CustomerName) ? "Walk-in" : o.CustomerName)</strong>
                                    <div style="color: var(--bo-text-subtle); font-size: var(--bo-font-xs);">@o.CustomerPhone</div>
                                </td>
                                <td style="padding:10px 14px; text-align:right;">@o.ItemCount</td>
                                <td style="padding:10px 14px; text-align:right;"><strong style="font-size:14px;">@o.Currency @o.Total.ToString("0.##")</strong></td>
                                <td style="padding:10px 14px;"><BoBadge Tone="@StatusTone(o.Status)">@o.Status</BoBadge></td>
                                <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                    <BoButton Variant="primary" Size="sm" OnClick="@(() => TakePaymentAsync(o))">Take payment</BoButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* Paid today — reprint / view receipt *@
        <div class="cc-section">
            <BoIcon Name="DocumentCheckmark" Size="18" />
            <span>Paid today</span>
            <BoBadge Tone="@(_paidToday.Count == 0 ? "neutral" : "success")">@_paidToday.Count</BoBadge>
        </div>
        @if (_paidToday.Count == 0)
        {
            <EmptyState Icon="Wallet" Description="No payments recorded today yet." />
        }
        else
        {
            <div class="bo-panel" style="padding:0; overflow:hidden;">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th class="cc-th">Order #</th>
                            <th class="cc-th">Customer</th>
                            <th class="cc-th">Method</th>
                            <th class="cc-th" style="text-align:right;">Total</th>
                            <th class="cc-th" style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _paidToday)
                        {
                            <tr class="cc-row">
                                <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@o.OrderNumber</span></td>
                                <td style="padding:10px 14px;">@(string.IsNullOrEmpty(o.CustomerName) ? "Walk-in" : o.CustomerName)</td>
                                <td style="padding:10px 14px;">
                                    @if (o.PaymentMethod is { } m)
                                    {
                                        <span style="display:inline-flex; align-items:center; gap:6px;">
                                            <BoIcon Name="@MethodIcon(m)" Size="15" />
                                            <BoBadge Tone="@MethodTone(m)">@m</BoBadge>
                                        </span>
                                    }
                                    else
                                    {
                                        <BoBadge Tone="success">Paid</BoBadge>
                                    }
                                </td>
                                <td style="padding:10px 14px; text-align:right;"><strong>@o.Currency @o.Total.ToString("0.##")</strong></td>
                                <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                    <BoButton Variant="outline" Size="sm" Loading="@(_printingId == o.Id)" OnClick="@(() => ReprintAsync(o))">Reprint</BoButton>
                                    <a class="bo-btn bo-btn-ghost" href="/reports/order/@o.Id/receipt.pdf" target="_blank">Invoice</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

<style>
    .cc-stat-sub { font-size: var(--bo-font-xs); color: var(--bo-text-subtle); }
    .cc-section { display:flex; align-items:center; gap:8px; font-size:15px; font-weight:700; margin:22px 0 10px; color:var(--bo-text); }
    .cc-th { padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); }
    .cc-row { border-top:1px solid var(--bo-border-soft); transition: background .1s; }
    .cc-row:hover { background: var(--bo-bg-soft); }
</style>
