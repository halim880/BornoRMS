@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@inject IWebHostEnvironment Env

<PageTitle>Sign in · BornoBit Restaurant ERP</PageTitle>

<div class="login">

    @* ============================ HERO ============================ *@
    <aside class="login-hero" aria-hidden="true">
        <svg class="login-hero-art" viewBox="0 0 600 900" preserveAspectRatio="xMidYMid slice">
            <defs>
                <radialGradient id="bbSun" cx="20%" cy="84%" r="60%">
                    <stop offset="0%" stop-color="currentColor" stop-opacity="0.35" />
                    <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
                </radialGradient>
            </defs>
            <circle cx="120" cy="760" r="320" fill="url(#bbSun)" />

            @* plate rings, top-right *@
            <g fill="none" stroke="currentColor" stroke-opacity="0.16" stroke-width="1.4">
                <circle cx="470" cy="180" r="150" />
                <circle cx="470" cy="180" r="112" />
                <circle cx="470" cy="180" r="74" stroke-dasharray="3 7" />
            </g>

            @* fork & knife line art *@
            <g stroke="currentColor" stroke-opacity="0.22" stroke-width="2.2" fill="none"
               stroke-linecap="round" stroke-linejoin="round" transform="translate(452,128) rotate(8)">
                <path d="M0 0 V40 M9 0 V40 M18 0 V40 M9 40 V96" />
                <path d="M44 0 C58 14 58 40 44 52 L44 96" />
            </g>

            @* steam swirls + bowl *@
            <g stroke="currentColor" stroke-opacity="0.24" stroke-width="2.4" fill="none" stroke-linecap="round">
                <path d="M150 470 c-18 -22 18 -40 0 -64 c-16 -22 14 -40 0 -60" />
                <path d="M196 482 c-18 -22 18 -40 0 -64 c-16 -22 14 -40 0 -60" />
                <path d="M242 470 c-18 -22 18 -40 0 -64 c-16 -22 14 -40 0 -60" />
            </g>
            <path d="M118 486 h172 a86 86 0 0 1 -172 0 z" fill="currentColor" fill-opacity="0.12"
                  stroke="currentColor" stroke-opacity="0.22" stroke-width="2" />

            @* scattered seeds *@
            <g fill="currentColor" fill-opacity="0.28">
                <circle cx="80" cy="150" r="3" /><circle cx="138" cy="96" r="2" /><circle cx="60" cy="320" r="2.4" />
                <circle cx="520" cy="560" r="2.6" /><circle cx="430" cy="640" r="2" /><circle cx="500" cy="720" r="3" />
                <circle cx="360" cy="430" r="2.2" /><circle cx="280" cy="700" r="2.4" />
            </g>
        </svg>

        <div class="login-hero-brand">
            <img class="brand-mark" src="/favicon.svg" alt="" />
            <div class="brand-text">
                <span class="brand-name">BornoBit</span>
                <span class="brand-sub">Restaurant ERP</span>
            </div>
        </div>

        <div class="login-hero-tag">
            <span class="login-hero-chip">
                <span class="login-hero-dot"></span>
                Kitchen open · Service ready
            </span>
            <h2 class="login-hero-title">Every great service starts behind the pass.</h2>
        </div>
    </aside>

    @* ============================ FORM ============================ *@
    <main class="login-panel">
        <div class="login-card">

            <p class="login-eyebrow">Staff Terminal</p>
            <header class="login-head">
                <h1 class="login-title">Welcome back</h1>
                <p class="login-subtitle">Sign in to open your shift and start taking orders.</p>
            </header>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div role="alert" class="login-error">
                    <span class="login-error-dot">!</span>
                    <span>@_error</span>
                </div>
            }

            <form action="/account/login" method="post" class="login-form" onsubmit="return boLoginSubmit(this)">
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                <label for="userName" class="field-label">Email / Username</label>
                <div class="field">
                    <span class="field-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="5" width="18" height="14" rx="2" />
                            <path d="m3 7 9 6 9-6" />
                        </svg>
                    </span>
                    <input id="userName" name="userName" type="text" required autofocus
                           autocomplete="username" placeholder="you@bornobit.local" class="field-input" />
                </div>

                <label for="password" class="field-label">Password</label>
                <div class="field">
                    <span class="field-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="4" y="10" width="16" height="11" rx="2" />
                            <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        </svg>
                    </span>
                    <input id="password" name="password" type="password" required
                           autocomplete="current-password" placeholder="Enter your password" class="field-input" />
                    <button type="button" class="field-eye" aria-label="Show password"
                            title="Show / hide password" onclick="boTogglePw(this)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>

                <div class="login-options">
                    <label class="remember">
                        <input type="checkbox" name="rememberMe" value="true" />
                        <span>Keep me signed in</span>
                    </label>
                    <a href="#" class="link">Forgot password?</a>
                </div>

                <button type="submit" class="login-submit">
                    <span class="login-submit-label">Sign in &amp; open shift</span>
                    <span class="login-submit-spinner" aria-hidden="true"></span>
                </button>
            </form>

            <div class="login-divider"><span>or</span></div>

            <button type="button" class="login-pin" disabled title="Coming soon">
                <span class="login-pin-hash">#</span> Sign in with manager PIN
            </button>

            <div class="login-support">
                Trouble signing in? <span class="muted">Ask your shift manager</span>
                <span class="dot">·</span>
                <a href="#" class="link">Contact support</a>
            </div>

            @if (Env.IsDevelopment())
            {
                <div class="login-dev">
                    <strong>Dev sign-in</strong>
                    <code>admin@bornobit.local</code> / <code>ChangeMe!2026</code>
                </div>
            }

            <footer class="login-foot">
                <span>Version 1.0</span>
                <span class="dot">·</span>
                <span>© 2026 BornoBit Technologies</span>
            </footer>
        </div>
    </main>
</div>

<script>
    function boTogglePw(btn) {
        var input = btn.parentElement.querySelector('input');
        if (!input) return;
        var show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        btn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
        btn.classList.toggle('is-on', show);
    }

    function boLoginSubmit(form) {
        var btn = form.querySelector('.login-submit');
        if (btn) {
            btn.classList.add('is-loading');
            btn.setAttribute('disabled', 'disabled');
            var label = btn.querySelector('.login-submit-label');
            if (label) label.textContent = 'Signing in…';
        }
        return true; // allow the native POST to proceed
    }
</script>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? ErrorCode { get; set; }

    private string? _error => ErrorCode switch
    {
        "invalid" => "Invalid credentials. Please try again.",
        "missing" => "Please enter both username and password.",
        _ => null
    };
}
