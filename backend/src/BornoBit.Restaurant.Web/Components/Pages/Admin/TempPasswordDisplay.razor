<BoDialogBody>
    <BoMessageBar Intent="warning">
        Save this password — it won't be shown again. Share it with the user via a secure channel.
    </BoMessageBar>
    <div style="margin-top:16px;padding:12px;background:var(--neutral-fill-input-rest);border-radius:4px;font-family:monospace;font-size:18px;letter-spacing:1px;text-align:center;">
        @Content
    </div>
</BoDialogBody>

<BoDialogFooter>
    <BoButton Variant="primary" OnClick="OnOkClick">OK</BoButton>
</BoDialogFooter>

@code {
    [Parameter] public string Content { get; set; } = string.Empty;
    [CascadingParameter] public BoDialogInstance Dialog { get; set; } = default!;

    private void OnOkClick() => Dialog.Close();
}
