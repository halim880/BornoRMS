@using BornoBit.Restaurant.Application.Tenants
@using FluentValidation
@using MediatR
@inject ISender Mediator

<BoDialogBody>
    <div style="display:flex; flex-direction:column; gap:14px;">
        @if (!string.IsNullOrEmpty(_error))
        {
            <BoMessageBar Intent="error">@_error</BoMessageBar>
        }

        <BoInput @bind-Value="Content.Name" Label="Name"  Required="true" Style="width:100%;" Placeholder="Acme Diagnostics" />

        @if (IsEdit)
        {
            <BoInput Value="@Content.Subdomain" Label="Subdomain"  ReadOnly="true" Style="width:100%;" />
            <small style="color:var(--neutral-foreground-hint);margin-top:-8px;">Subdomain is immutable once a tenant is created.</small>
        }
        else
        {
            <BoInput @bind-Value="Content.Subdomain" Label="Subdomain"  Required="true" Style="width:100%;" Placeholder="acme" />
            <small style="color:var(--neutral-foreground-hint);margin-top:-8px;">Lowercase letters, digits, and hyphens. Becomes acme.@(_rootDomain).</small>
        }

        <BoInput @bind-Value="Content.ContactEmail" Label="Contact email"  Required="true" Style="width:100%;" Placeholder="admin@acme.com" />

        <BoDatePicker DateTimeValue="Content.LicenseExpiresOnUtc" DateTimeValueChanged="@(v => Content.LicenseExpiresOnUtc = v)" Label="License expires (optional)" />
    </div>
</BoDialogBody>

<BoDialogFooter>
    <BoButton Variant="ghost" OnClick="CancelAsync" Disabled="_busy">Cancel</BoButton>
    <BoButton Variant="primary" OnClick="SaveAsync" Loading="_busy">@(IsEdit ? "Save changes" : "Create tenant")</BoButton>
</BoDialogFooter>

@code {
    [Parameter] public TenantFormModel Content { get; set; } = default!;
    [CascadingParameter] public BoDialogInstance Dialog { get; set; } = default!;

    [Inject] public IConfiguration Config { get; set; } = default!;

    private string? _error;
    private bool _busy;
    private string _rootDomain = "localhost";

    private bool IsEdit => Content.Id is not null;

    protected override void OnInitialized()
    {
        _rootDomain = Config["Tenancy:RootDomain"] ?? "localhost";
    }

    private async Task SaveAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            if (IsEdit)
            {
                await Mediator.Send(new UpdateTenantCommand(
                    Content.Id!.Value,
                    (Content.Name ?? string.Empty).Trim(),
                    (Content.ContactEmail ?? string.Empty).Trim(),
                    Content.LicenseExpiresOnUtc));
            }
            else
            {
                Content.Id = await Mediator.Send(new CreateTenantCommand(
                    (Content.Name ?? string.Empty).Trim(),
                    (Content.Subdomain ?? string.Empty).Trim(),
                    (Content.ContactEmail ?? string.Empty).Trim(),
                    Content.LicenseExpiresOnUtc));
            }
            Dialog.Close(Content);
        }
        catch (ValidationException vex)
        {
            _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CancelAsync() => Dialog.Cancel();
}
