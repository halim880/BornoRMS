@page "/settings/app"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>App Settings · BornoBit.Restaurant</PageTitle>

<div class="hc-page">
    <PageHeader Title="App Settings" Description="Personal preferences for this browser. These choices are saved locally and don't affect other users." />

    <div class="hc-grid-2" style="align-items:start;">
        <div class="hc-card">
            <div class="hc-card-header">
                <div>
                    <h3 class="hc-card-title">Theme color</h3>
                    <p class="hc-card-subtitle">Pick the accent color used across buttons, links, and highlights.</p>
                </div>
            </div>
            <ThemePicker />
        </div>

        <div class="hc-card">
            <div class="hc-card-header">
                <div>
                    <h3 class="hc-card-title">About</h3>
                    <p class="hc-card-subtitle">More personalization options will land here.</p>
                </div>
            </div>
            <div class="hc-text-muted" style="font-size: var(--hc-font-sm); line-height:1.6;">
                Theme preferences are stored in your browser's local storage. Clearing site data or switching browsers will reset them.
            </div>
        </div>
    </div>
</div>
