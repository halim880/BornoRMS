@page "/stock/suppliers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Admin")]
@using BornoBit.Restaurant.Application.Inventory.Suppliers

<PageTitle>Suppliers · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Suppliers"
                Description="Bazar vendors and wholesalers you receive stock from.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Supplier</button>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading suppliers…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_suppliers.Count == 0)
    {
        <EmptyState Description="No suppliers yet. Click '+ New Supplier' to add one." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Code</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Name</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Phone</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Terms</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:center;">Status</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _suppliers)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft); @(s.IsActive ? "" : "opacity:0.55;")">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@s.Code</span></td>
                            <td style="padding:10px 14px;"><strong>@s.Name</strong></td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@(string.IsNullOrEmpty(s.Phone) ? "—" : s.Phone)</td>
                            <td style="padding:10px 14px; text-align:right; color: var(--bo-text-muted);">@(s.PaymentTermsDays == 0 ? "Cash" : $"{s.PaymentTermsDays} d")</td>
                            <td style="padding:10px 14px; text-align:center;">
                                <span class="bo-pill @(s.IsActive ? "bo-pill-active" : "bo-pill-inactive")">@(s.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(s))">Edit</button>
                                @if (s.IsActive)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(s, false))">Deactivate</button>
                                }
                                else
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(s, true))">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
