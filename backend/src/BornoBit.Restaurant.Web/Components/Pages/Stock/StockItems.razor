@page "/stock/items"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Inventory")]
@using BornoBit.Restaurant.Application.Inventory.Categories
@using BornoBit.Restaurant.Application.Inventory.Items
@using BornoBit.Restaurant.Domain.Inventory
@using BornoBit.Restaurant.Web.Components.BornoUi

<PageTitle>Stock Items · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Stock Items"
                Description="Raw ingredients and finished goods tracked in inventory. On-hand and average cost update as you receive, waste and adjust stock.">
        <Actions>
            <button type="button" class="bo-btn bo-btn-ghost" @onclick="PrintPdfAsync">Print PDF</button>
            <button type="button" class="bo-btn bo-btn-primary" @onclick="ShowCreateAsync">+ New Item</button>
        </Actions>
    </PageHeader>

    <div class="bo-card" style="display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; margin-bottom:16px;">
        <div style="flex:1 1 260px; min-width:220px;">
            <BoSearch Value="_search" ValueChanged="OnSearchChanged" DebounceMs="300"
                      Placeholder="Search code, name or Bangla name…" />
        </div>
        <BoSelect TOption="InventoryCategoryDto"
                  Items="_categories"
                  OptionValue="@(c => c.Id.ToString())"
                  OptionText="@(c => c.Name)"
                  SelectedOption="_selectedCategory"
                  SelectedOptionChanged="OnCategoryChanged"
                  Label="Category" Placeholder="(all categories)" />
        <BoSelect TOption="TypeOption"
                  Items="_typeOptions"
                  OptionValue="@(o => o.Key)"
                  OptionText="@(o => o.Label)"
                  SelectedOption="_selectedType"
                  SelectedOptionChanged="OnTypeChanged"
                  Label="Type" />
        <div style="display:flex; flex-direction:column; gap:6px; padding-bottom:4px;">
            <BoCheckbox Value="_lowStockOnly" ValueChanged="OnLowStockChanged" Label="Low stock only" />
            <BoCheckbox Value="_showInactive" ValueChanged="OnShowInactiveChanged" Label="Show inactive" />
        </div>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading stock items…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        <div class="bo-card" style="display:flex; flex-wrap:wrap; gap:24px; margin-bottom:16px;">
            <div>
                <div style="font-size:var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color:var(--bo-text-muted);">Items</div>
                <div style="font-size:var(--bo-font-lg); font-weight:600;">@_summary.ItemCount</div>
            </div>
            <div>
                <div style="font-size:var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color:var(--bo-text-muted);">Total stock value</div>
                <div style="font-size:var(--bo-font-lg); font-weight:600;">@_summary.TotalStockValue.ToString("#,##0.00") Tk</div>
            </div>
            <div>
                <div style="font-size:var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color:var(--bo-text-muted);">Low stock</div>
                <div style="font-size:var(--bo-font-lg); font-weight:600; color:@(_summary.LowStockCount > 0 ? "var(--bo-danger)" : "inherit");">@_summary.LowStockCount</div>
            </div>
        </div>

        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="@HeadStyle" @onclick="@(() => SortByAsync("code"))" role="button">Code@(SortIndicator("code"))</th>
                        <th style="@HeadStyle" @onclick="@(() => SortByAsync("name"))" role="button">Name@(SortIndicator("name"))</th>
                        <th style="@HeadStyle" @onclick="@(() => SortByAsync("category"))" role="button">Category@(SortIndicator("category"))</th>
                        <th style="@HeadStylePlain">Type</th>
                        <th style="@HeadStyleRight" @onclick="@(() => SortByAsync("qty"))" role="button">On hand@(SortIndicator("qty"))</th>
                        <th style="@HeadStyleRight" @onclick="@(() => SortByAsync("reorder"))" role="button">Reorder@(SortIndicator("reorder"))</th>
                        <th style="@HeadStyleRight" @onclick="@(() => SortByAsync("avgcost"))" role="button">Avg cost@(SortIndicator("avgcost"))</th>
                        <th style="@HeadStyleRight" @onclick="@(() => SortByAsync("value"))" role="button">Value@(SortIndicator("value"))</th>
                        <th style="@HeadStylePlainRight">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_items.Count == 0)
                    {
                        <tr>
                            <td colspan="9" style="padding:28px 14px; text-align:center; color:var(--bo-text-muted);">
                                @(_hasFilters ? "No items match the current filters." : "No stock items yet. Click '+ New Item' to add one.")
                            </td>
                        </tr>
                    }
                    @foreach (var i in _items)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft); @(i.IsActive ? "" : "opacity:0.55;")">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@i.Code</span></td>
                            <td style="padding:10px 14px;">
                                <strong>@i.Name</strong>
                                @if (!string.IsNullOrEmpty(i.BanglaName))
                                {
                                    <div style="color: var(--bo-text-subtle); font-size: var(--bo-font-xs);">@i.BanglaName</div>
                                }
                            </td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@i.CategoryName</td>
                            <td style="padding:10px 14px;">@(i.ItemType == InventoryItemType.Ingredient ? "Ingredient" : "Finished")</td>
                            <td style="padding:10px 14px; text-align:right;">
                                @i.QtyOnHand.ToString("0.###") @i.UnitCode
                                @if (i.IsLowStock)
                                {
                                    <BoBadge Tone="danger">Low</BoBadge>
                                }
                            </td>
                            <td style="padding:10px 14px; text-align:right; color: var(--bo-text-muted);">@i.ReorderLevel.ToString("0.###")</td>
                            <td style="padding:10px 14px; text-align:right;">@i.AvgCost.ToString("0.00") @i.Currency</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:600;">@i.StockValue.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowEditAsync(i))">Edit</button>
                                <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ShowAdjustAsync(i))">Adjust</button>
                                @if (i.IsActive)
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(i, false))">Deactivate</button>
                                }
                                else
                                {
                                    <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => ToggleActiveAsync(i, true))">Activate</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; padding:12px 14px; border-top:1px solid var(--bo-border-soft);">
                <div style="color:var(--bo-text-muted); font-size:var(--bo-font-sm);">
                    Page @_page of @_totalPages · @_totalCount total
                </div>
                <div style="display:flex; align-items:center; gap:8px;">
                    <BoSelect TOption="PageSizeOption"
                              Items="_pageSizeOptions"
                              OptionValue="@(o => o.Value.ToString())"
                              OptionText="@(o => o.Label)"
                              SelectedOption="_selectedPageSize"
                              SelectedOptionChanged="OnPageSizeChanged" />
                    <button class="bo-btn bo-btn-ghost" disabled="@(_page <= 1)" @onclick="PrevPageAsync">Previous</button>
                    <button class="bo-btn bo-btn-ghost" disabled="@(_page >= _totalPages)" @onclick="NextPageAsync">Next</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private const string HeadStyle = "padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); cursor:pointer; user-select:none;";
    private const string HeadStyleRight = "padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); text-align:right; cursor:pointer; user-select:none;";
    private const string HeadStylePlain = "padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted);";
    private const string HeadStylePlainRight = "padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; letter-spacing:0.06em; color: var(--bo-text-muted); text-align:right;";
}
