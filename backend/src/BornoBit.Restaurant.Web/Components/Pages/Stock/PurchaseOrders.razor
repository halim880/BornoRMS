@page "/stock/po"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Inventory")]
@using BornoBit.Restaurant.Application.Inventory.PurchaseOrders
@using BornoBit.Restaurant.Domain.Inventory

<PageTitle>Purchase Orders · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Purchase Orders"
                Description="Raise orders to suppliers, approve them, then receive goods against them. Posting a goods receipt matched to an order updates its received quantities.">
        <Actions>
            <a class="bo-btn bo-btn-primary" href="/stock/po/new">+ New Purchase Order</a>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading purchase orders…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_rows.Count == 0)
    {
        <EmptyState Description="No purchase orders yet. Click '+ New Purchase Order' to raise one." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">PO #</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Supplier</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Ordered</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Expected</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Lines</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Subtotal</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:center;">Status</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@p.PoNumber</span></td>
                            <td style="padding:10px 14px;"><strong>@p.SupplierName</strong></td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@p.OrderedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@(p.ExpectedAtUtc is { } e ? e.ToLocalTime().ToString("yyyy-MM-dd") : "—")</td>
                            <td style="padding:10px 14px; text-align:right;">@p.LineCount</td>
                            <td style="padding:10px 14px; text-align:right;">@p.Subtotal.ToString("0.00") @p.Currency</td>
                            <td style="padding:10px 14px; text-align:center;">
                                <BoBadge Tone="@StatusTone(p.Status)">@StatusLabel(p.Status)</BoBadge>
                            </td>
                            <td style="padding:10px 14px; text-align:right;">
                                <div style="display:inline-flex; gap:6px; justify-content:flex-end;">
                                    <a class="bo-btn bo-btn-ghost" href="@($"/stock/po/{p.Id}")">View</a>
                                    @if (p.Status == PurchaseOrderStatus.Draft)
                                    {
                                        <a class="bo-btn bo-btn-ghost" href="@($"/stock/po/{p.Id}/edit")">Edit</a>
                                        <button type="button" class="bo-btn bo-btn-primary" @onclick="@(() => ApproveAsync(p))" disabled="@_busy">Approve</button>
                                    }
                                    else if (p.Status is PurchaseOrderStatus.Approved or PurchaseOrderStatus.PartiallyReceived)
                                    {
                                        <a class="bo-btn bo-btn-primary" href="@($"/stock/po/{p.Id}/receive")">Receive</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
