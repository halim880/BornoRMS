@page "/stock/grn"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Inventory")]
@using BornoBit.Restaurant.Application.Inventory.Purchases
@using BornoBit.Restaurant.Domain.Inventory

<PageTitle>Goods Receipts · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Goods Receipts"
                Description="Record stock received from suppliers. Posting a receipt raises on-hand quantities and recomputes average cost.">
        <Actions>
            <a class="bo-btn bo-btn-primary" href="/stock/grn/new">+ New Receipt</a>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading goods receipts…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_rows.Count == 0)
    {
        <EmptyState Description="No goods receipts yet. Click '+ New Receipt' to record a delivery." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">GRN #</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Supplier</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Invoice</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Received</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Lines</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Subtotal</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:center;">Status</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in _rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@g.GrnNumber</span></td>
                            <td style="padding:10px 14px;"><strong>@g.SupplierName</strong></td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@(string.IsNullOrEmpty(g.InvoiceNo) ? "— (cash)" : g.InvoiceNo)</td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@g.ReceivedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td style="padding:10px 14px; text-align:right;">@g.LineCount</td>
                            <td style="padding:10px 14px; text-align:right;">@g.Subtotal.ToString("0.00") @g.Currency</td>
                            <td style="padding:10px 14px; text-align:center;">
                                <BoBadge Tone="@(g.Status == GoodsReceiptStatus.Posted ? "success" : "warning")">@g.Status</BoBadge>
                            </td>
                            <td style="padding:10px 14px; text-align:right;">
                                <div style="display:inline-flex; gap:6px; justify-content:flex-end;">
                                    @if (g.Status == GoodsReceiptStatus.Draft)
                                    {
                                        <a class="bo-btn bo-btn-ghost" href="@($"/stock/grn/{g.Id}/edit")">Edit</a>
                                        <button type="button" class="bo-btn bo-btn-ghost" @onclick="@(() => DeleteAsync(g))" disabled="@_busy">Delete</button>
                                        <button type="button" class="bo-btn bo-btn-primary" @onclick="@(() => PostAsync(g))" disabled="@_busy">Post</button>
                                    }
                                    else
                                    {
                                        <a class="bo-btn bo-btn-ghost" href="@($"/stock/grn/{g.Id}")">View</a>
                                        <a class="bo-btn bo-btn-ghost" href="@($"/reports/grn/{g.Id}/receipt.pdf")" target="_blank">Print</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
