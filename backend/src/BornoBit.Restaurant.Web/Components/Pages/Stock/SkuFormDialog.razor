@using BornoBit.Restaurant.Application.Inventory.Categories
@using BornoBit.Restaurant.Application.Inventory.Skus
@using BornoBit.Restaurant.Application.Inventory.Units
@using FluentValidation
@using MediatR
@inject ISender Mediator

<BoDialogBody>
    <div style="display:flex; flex-direction:column; gap:12px;">
        @if (!string.IsNullOrEmpty(_error))
        {
            <BoMessageBar Intent="error">@_error</BoMessageBar>
        }

        <div class="bo-cmp-field-hint">
            SKU for <strong>@Content.ProductName</strong>@(Content.VariantName is null ? "" : $" · {Content.VariantName}")
        </div>

        <div style="display:flex; gap:12px;">
            <BoInput @bind-Value="Content.Code" Label="Code" Required="true" Style="flex:1;" Maxlength="40" />
            <BoSelect TOption="UnitDto"
                      Items="@_units"
                      OptionValue="@(u => u.Id.ToString())"
                      OptionText="@UnitLabel"
                      SelectedOption="@_selectedUnit"
                      SelectedOptionChanged="@(u => Content.BaseUnitId = u?.Id ?? Guid.Empty)"
                      Label="Base unit" Placeholder="Select a unit" Required="true" Style="width:200px;" />
        </div>

        <BoInput @bind-Value="Content.Name" Label="Name" Required="true" Style="width:100%;" Maxlength="200" />
        <BoInput @bind-Value="Content.BanglaName" Label="Bangla name (বাংলা নাম)" Style="width:100%;" Maxlength="200" />

        <BoSelect TOption="InventoryCategoryDto"
                  Items="@_categories"
                  OptionValue="@(c => c.Id.ToString())"
                  OptionText="@(c => c.Name)"
                  SelectedOption="@_selectedCategory"
                  SelectedOptionChanged="@(c => Content.InventoryCategoryId = c?.Id ?? Guid.Empty)"
                  Label="Category" Placeholder="Select a category" Required="true" Style="width:100%;" />

        <div style="display:flex; gap:12px;">
            <BoNumeric T="decimal" @bind-Value="Content.ReorderLevel" Label="Reorder level" Style="flex:1;" Min="0" Step="0.001" Decimals="3" />
            <BoNumeric T="decimal" @bind-Value="Content.ReorderQty" Label="Reorder qty" Style="flex:1;" Min="0" Step="0.001" Decimals="3" />
        </div>

        <div style="display:flex; gap:12px; align-items:flex-end;">
            <BoNumeric T="decimal?" @bind-Value="Content.PackSize" Label="Pack size (optional)" Style="width:220px;" Min="0" Step="0.001" Decimals="3" />
            <BoInput @bind-Value="Content.PackNote" Label="Pack note" Style="flex:1;" Maxlength="200" Placeholder="e.g. 1 carton = 24 pcs" />
        </div>

        <BoCheckbox @bind-Value="Content.IsPerishable" Label="Perishable (high spoilage risk)" />
    </div>
</BoDialogBody>

<BoDialogFooter>
    <BoButton Variant="ghost" OnClick="CancelAsync" Disabled="_busy">Cancel</BoButton>
    <BoButton Variant="primary" OnClick="SaveAsync" Loading="_busy">Create SKU</BoButton>
</BoDialogFooter>

@code {
    [Parameter] public SkuFormModel Content { get; set; } = default!;
    [CascadingParameter] public BoDialogInstance Dialog { get; set; } = default!;

    private string? _error;
    private bool _busy;
    private List<InventoryCategoryDto> _categories = new();
    private List<UnitDto> _units = new();

    private InventoryCategoryDto? _selectedCategory => _categories.FirstOrDefault(c => c.Id == Content.InventoryCategoryId);
    private UnitDto? _selectedUnit => _units.FirstOrDefault(u => u.Id == Content.BaseUnitId);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _categories = (await Mediator.Send(new GetInventoryCategoriesQuery())).Where(c => c.IsActive).ToList();
            _units = (await Mediator.Send(new GetUnitsQuery())).Where(u => u.IsActive).ToList();

            // Default a finished-goods category for convenience (packaged drinks etc.).
            if (Content.InventoryCategoryId == Guid.Empty)
                Content.InventoryCategoryId = (_categories.FirstOrDefault(c => c.Name.Contains("Finished", StringComparison.OrdinalIgnoreCase))
                    ?? _categories.FirstOrDefault())?.Id ?? Guid.Empty;
        }
        catch (Exception ex) { _error = $"Failed to load reference data: {ex.Message}"; }
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(Content.Code)) { _error = "Code is required."; return; }
        if (string.IsNullOrWhiteSpace(Content.Name)) { _error = "Name is required."; return; }
        if (Content.InventoryCategoryId == Guid.Empty) { _error = "Category is required."; return; }
        if (Content.BaseUnitId == Guid.Empty) { _error = "Base unit is required."; return; }

        _busy = true;
        try
        {
            var id = await Mediator.Send(new CreateSkuForProductCommand(
                Content.ProductId, Content.VariantId,
                Content.Code.Trim(), Content.Name.Trim(), Norm(Content.BanglaName),
                Content.InventoryCategoryId, Content.BaseUnitId,
                Content.ReorderLevel, Content.ReorderQty, Content.IsPerishable,
                Content.PackSize, Norm(Content.PackNote)));
            Content.SavedId = id;
            Dialog.Close(Content);
        }
        catch (ValidationException vex) { _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage)); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync() => Dialog.Cancel();

    private static string UnitLabel(UnitDto u) => $"{u.Code} · {u.Name}";

    private static string? Norm(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}
