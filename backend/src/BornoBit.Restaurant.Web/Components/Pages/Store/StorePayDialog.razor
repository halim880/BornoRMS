@using BornoBit.Restaurant.Application.Store.Payments
@using BornoBit.Restaurant.Domain.Store
@using FluentValidation
@using MediatR
@inject ISender Mediator

<BoDialogBody>
    <div style="display:flex; flex-direction:column; gap:12px;">
        @if (!string.IsNullOrEmpty(_error))
        {
            <BoMessageBar Intent="error">@_error</BoMessageBar>
        }

        <div style="color: var(--bo-text-muted);">
            <strong>@Content.SupplierName</strong> · outstanding:
            <strong>@Content.Outstanding.ToString("#,##0.00")</strong>
        </div>

        <BoNumeric T="decimal" @bind-Value="Content.Amount" Label="Amount" Style="width:100%;" Min="0" Step="0.01" Decimals="2" />

        <BoSelect TOption="StorePaymentMethod"
                  Items="_methods"
                  OptionValue="@(m => ((int)m).ToString())"
                  OptionText="@(m => m.ToString())"
                  SelectedOption="Content.Method"
                  SelectedOptionChanged="@(m => Content.Method = m)"
                  Label="Method" Style="width:100%;" />

        <BoInput @bind-Value="Content.Reference" Label="Reference (optional)" Style="width:100%;" Maxlength="120" Placeholder="e.g. cheque no / txn id" />
        <BoInput @bind-Value="Content.Notes" Label="Notes (optional)" Style="width:100%;" Maxlength="1000" />
    </div>
</BoDialogBody>

<BoDialogFooter>
    <BoButton Variant="ghost" OnClick="CancelAsync" Disabled="_busy">Cancel</BoButton>
    <BoButton Variant="primary" OnClick="SaveAsync" Loading="_busy">Record payment</BoButton>
</BoDialogFooter>

@code {
    [Parameter] public StorePayModel Content { get; set; } = default!;
    [CascadingParameter] public BoDialogInstance Dialog { get; set; } = default!;

    private static readonly StorePaymentMethod[] _methods = Enum.GetValues<StorePaymentMethod>();
    private string? _error;
    private bool _busy;

    private async Task SaveAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await Mediator.Send(new RecordStorePaymentCommand(
                Content.SupplierId, Content.Amount, null, Content.Method,
                string.IsNullOrWhiteSpace(Content.Reference) ? null : Content.Reference.Trim(),
                string.IsNullOrWhiteSpace(Content.Notes) ? null : Content.Notes.Trim()));
            Content.Saved = true;
            Dialog.Close(Content);
        }
        catch (ValidationException vex) { _error = string.Join("; ", vex.Errors.Select(e => e.ErrorMessage)); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task CancelAsync() => Dialog.Cancel();
}
