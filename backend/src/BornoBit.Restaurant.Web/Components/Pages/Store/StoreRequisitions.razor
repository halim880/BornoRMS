@page "/store/requisitions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Store")]
@using BornoBit.Restaurant.Application.Store.Departments
@using BornoBit.Restaurant.Application.Store.Requisitions
@using BornoBit.Restaurant.Domain.Store

<PageTitle>Store Requisitions · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Store Requisitions"
                Description="Department requests for stock. Submit → approve → fulfil into an issue that lowers on-hand quantities.">
        <Actions>
            <BoSelect TOption="StoreDepartmentDto"
                      Items="@_departments"
                      OptionValue="@(d => d.Id.ToString())"
                      OptionText="@(d => d.Name)"
                      SelectedOption="@_departments.FirstOrDefault(d => d.Id == _filterDepartmentId)"
                      SelectedOptionChanged="OnFilterDepartmentChanged"
                      Placeholder="All departments" Style="min-width:200px;" />
            <a class="bo-btn bo-btn-primary" href="/store/requisitions/new">+ New Requisition</a>
        </Actions>
    </PageHeader>

    @if (_loading)
    {
        <LoadingState Message="Loading requisitions…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else if (_rows.Count == 0)
    {
        <EmptyState Description="No requisitions yet. Click '+ New Requisition' to raise one." />
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Requisition #</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Department</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted);">Requested (UTC)</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Lines</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:center;">Status</th>
                        <th style="padding:10px 14px; font-size: var(--bo-font-xs); text-transform:uppercase; color: var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><span class="bo-code bo-code-slate">@r.RequisitionNumber</span></td>
                            <td style="padding:10px 14px;"><strong>@r.DepartmentName</strong></td>
                            <td style="padding:10px 14px; color: var(--bo-text-muted);">@r.RequestedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td style="padding:10px 14px; text-align:right;">@r.LineCount</td>
                            <td style="padding:10px 14px; text-align:center;">
                                <BoBadge Tone="@StatusTone(r.Status)">@StatusLabel(r.Status)</BoBadge>
                            </td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <a class="bo-btn bo-btn-ghost" href="@($"/store/requisitions/{r.Id}")">View</a>
                                @if (r.Status == StoreRequisitionStatus.Draft)
                                {
                                    <a class="bo-btn bo-btn-ghost" href="@($"/store/requisitions/{r.Id}/edit")">Edit</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
