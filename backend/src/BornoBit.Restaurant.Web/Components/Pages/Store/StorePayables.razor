@page "/store/payables"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Store")]
@using BornoBit.Restaurant.Application.Store.Payments

<PageTitle>Store Payables · BornoBit.Restaurant</PageTitle>

<div class="bo-page">
    <PageHeader Title="Store Payables"
                Description="Amount owed per supplier (posted receipts minus payments). Record payments to settle balances." />

    @if (_loading)
    {
        <LoadingState Message="Loading payables…" />
    }
    else if (_error is not null)
    {
        <BoMessageBar Intent="error">@_error</BoMessageBar>
    }
    else
    {
        <div class="bo-card" style="padding:0; overflow:hidden; margin-bottom:16px;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bo-bg-soft); text-align:left;">
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Supplier</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Terms</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Billed</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Paid</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Outstanding</th>
                        <th style="padding:10px 14px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _rows)
                    {
                        <tr style="border-top:1px solid var(--bo-border-soft);">
                            <td style="padding:10px 14px;"><strong>@s.Name</strong><div style="font-size:var(--bo-font-xs); color:var(--bo-text-subtle);">@s.Code@(string.IsNullOrEmpty(s.Phone) ? "" : " · " + s.Phone)</div></td>
                            <td style="padding:10px 14px; color:var(--bo-text-muted);">@(s.PaymentTermsDays == 0 ? "Cash" : $"{s.PaymentTermsDays}d")</td>
                            <td style="padding:10px 14px; text-align:right;">@s.Billed.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; color:var(--bo-text-muted);">@s.Paid.ToString("#,##0.00")</td>
                            <td style="padding:10px 14px; text-align:right; font-weight:700;">
                                @s.Outstanding.ToString("#,##0.00")
                                @if (s.Outstanding > 0)
                                {
                                    <BoBadge Tone="warning">Due</BoBadge>
                                }
                                else if (s.Outstanding < 0)
                                {
                                    <BoBadge Tone="info">Advance</BoBadge>
                                }
                            </td>
                            <td style="padding:10px 14px; text-align:right; white-space:nowrap;">
                                <button type="button" class="bo-btn bo-btn-primary" @onclick="@(() => ShowPayAsync(s))">Record payment</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bo-card" style="padding:16px;">
            <strong>Recent payments</strong>
            @if (_payments.Count == 0)
            {
                <div style="padding:12px; color:var(--bo-text-subtle);">No payments recorded yet.</div>
            }
            else
            {
                <table style="width:100%; border-collapse:collapse; margin-top:10px;">
                    <thead>
                        <tr style="background:var(--bo-bg-soft); text-align:left;">
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Date (UTC)</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Supplier</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Method</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted);">Reference</th>
                            <th style="padding:8px 12px; font-size:var(--bo-font-xs); text-transform:uppercase; color:var(--bo-text-muted); text-align:right;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _payments)
                        {
                            <tr style="border-top:1px solid var(--bo-border-soft);">
                                <td style="padding:8px 12px; color:var(--bo-text-muted);">@p.PaidAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                <td style="padding:8px 12px;">@p.SupplierName</td>
                                <td style="padding:8px 12px; color:var(--bo-text-muted);">@p.Method</td>
                                <td style="padding:8px 12px; color:var(--bo-text-muted);">@(string.IsNullOrEmpty(p.Reference) ? "—" : p.Reference)</td>
                                <td style="padding:8px 12px; text-align:right;">@p.Amount.ToString("#,##0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>
