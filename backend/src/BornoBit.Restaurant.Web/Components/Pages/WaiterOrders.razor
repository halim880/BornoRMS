@page "/waiter/orders"
@attribute [Authorize(Policy = "WaiterFloor")]
@using Microsoft.AspNetCore.Authorization
@using BornoBit.Restaurant.Application.Dining.Queries
@using BornoBit.Restaurant.Application.Operations.Dashboard
@using BornoBit.Restaurant.Application.Operations.Sessions
@using BornoBit.Restaurant.Application.Ordering.Commands
@using BornoBit.Restaurant.Application.Ordering.Pos
@using BornoBit.Restaurant.Application.Ordering.Queries
@using BornoBit.Restaurant.Web.Components.Pages.POS
@using BornoBit.Restaurant.Application.ProductCategories
@using BornoBit.Restaurant.Application.Products
@using BornoBit.Restaurant.Domain.Dining
@using BornoBit.Restaurant.Domain.Ordering
@using BornoBit.Restaurant.Shared.Common
@rendermode InteractiveServer

<PageTitle>Waiter · BornoBit</PageTitle>

@if (_loading)
{
    <LoadingState Message="Loading waiter console…" />
}
else
{
    <!-- ============ HEADER ============ -->
    <div class="wc-head">
        <div class="wc-title">
            <h2>Waiter console</h2>
            <span class="wc-conn @(_connected ? "wc-conn--on" : "wc-conn--off")">
                <span class="wc-dot"></span>@(_connected ? "Live" : "Reconnecting…")
            </span>
        </div>
        <div class="wc-tabs">
            <button class="wc-tab @(_tab == WaiterTab.Floor ? "wc-tab--active" : null)" @onclick="() => SetTab(WaiterTab.Floor)">Floor</button>
            <button class="wc-tab @(_tab == WaiterTab.TakeOrder ? "wc-tab--active" : null)" @onclick="() => SetTab(WaiterTab.TakeOrder)">Take order</button>
            <button class="wc-tab @(_tab == WaiterTab.Ready ? "wc-tab--active" : null)" @onclick="() => SetTab(WaiterTab.Ready)">
                Ready @(_ready.Count > 0 ? $"({_ready.Count})" : "")
            </button>
            <button class="wc-tab @(_tab == WaiterTab.Requests ? "wc-tab--active" : null)" @onclick="() => SetTab(WaiterTab.Requests)">
                Requests @(_requests.Count > 0 ? $"({_requests.Count})" : "")
            </button>
        </div>
    </div>

    <!-- ============ WIDGET STRIP ============ -->
    @if (_widgets is { } w)
    {
        <div class="wc-widgets wc-section">
            <div class="wc-widget"><span class="wc-w-num">@w.MyTables</span><span class="wc-w-lbl">My tables</span></div>
            <div class="wc-widget wc-widget--ok"><span class="wc-w-num">@w.AvailableTables</span><span class="wc-w-lbl">Available</span></div>
            <div class="wc-widget wc-widget--warn"><span class="wc-w-num">@w.OccupiedTables</span><span class="wc-w-lbl">Occupied</span></div>
            <div class="wc-widget wc-widget--info"><span class="wc-w-num">@w.PendingRequests</span><span class="wc-w-lbl">Requests</span></div>
            <div class="wc-widget wc-widget--primary"><span class="wc-w-num">@w.ReadyToServeOrders</span><span class="wc-w-lbl">Ready to serve</span></div>
            <div class="wc-widget wc-widget--danger"><span class="wc-w-num">@w.BillsWaiting</span><span class="wc-w-lbl">Bills waiting</span></div>
            <div class="wc-widget"><span class="wc-w-num">@w.MyActiveSessions</span><span class="wc-w-lbl">My sessions</span></div>
            <div class="wc-widget"><span class="wc-w-num">@w.Currency @w.MyRevenueServedToday.ToString("0")</span><span class="wc-w-lbl">My revenue</span></div>
        </div>
    }

    @if (_tab == WaiterTab.Floor)
    {
        <!-- ============ FLOOR ============ -->
        <div class="wc-filters wc-section">
            <button class="flt @(_statusFilter is null ? "flt--active" : null)" @onclick="() => SetStatusFilter(null)">All</button>
            <button class="flt @(_statusFilter == DerivedTableStatus.Available ? "flt--active" : null)" @onclick="() => SetStatusFilter(DerivedTableStatus.Available)">Available</button>
            <button class="flt @(_statusFilter == DerivedTableStatus.Occupied ? "flt--active" : null)" @onclick="() => SetStatusFilter(DerivedTableStatus.Occupied)">Occupied</button>
            <button class="flt @(_statusFilter == DerivedTableStatus.WaitingPayment ? "flt--active" : null)" @onclick="() => SetStatusFilter(DerivedTableStatus.WaitingPayment)">Waiting payment</button>
            <button class="flt @(_statusFilter == DerivedTableStatus.Reserved ? "flt--active" : null)" @onclick="() => SetStatusFilter(DerivedTableStatus.Reserved)">Reserved</button>
            <label class="flt-mine">
                <input type="checkbox" checked="@_mineOnly" @onchange="e => _mineOnly = (bool)e.Value!" /> My tables only
            </label>
        </div>

        <div class="wc-floor-wrap wc-section">
            <div class="wc-floor">
                @foreach (var t in FilteredFloor)
                {
                    <button type="button" @key="t.TableId"
                            class="@($"tbl tbl--{TableTone(t.Status)} {(_selectedFloorTable?.TableId == t.TableId ? "tbl--sel" : "")}")"
                            @onclick="() => SelectFloorTable(t)">
                        <div class="tbl-top">
                            <span class="tbl-no">@t.TableNumber</span>
                            <BoBadge Tone="@TableTone(t.Status)">@TableStatusLabel(t.Status)</BoBadge>
                        </div>
                        <div class="tbl-meta">
                            <span>👥 @(t.GuestCount?.ToString() ?? "—")/@t.Capacity</span>
                            @if (t.SessionMinutes is { } m) { <span>⏱ @m m</span> }
                            @if (t.OrderCount > 0) { <span>🧾 @t.OrderCount</span> }
                        </div>
                        @if (t.CurrentBill > 0m)
                        {
                            <div class="tbl-bill">@t.Currency @t.CurrentBill.ToString("0.##")</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(t.WaiterName))
                        {
                            <div class="tbl-waiter">@t.WaiterName</div>
                        }
                    </button>
                }
            </div>

            @if (_selectedFloorTable is { } sel)
            {
                <div class="wc-actions">
                    <div class="wc-actions-head">
                        <strong>Table @sel.TableNumber</strong>
                        <BoBadge Tone="@TableTone(sel.Status)">@TableStatusLabel(sel.Status)</BoBadge>
                    </div>

                    @if (sel.SessionId is null)
                    {
                        <BoButton Variant="primary" OnClick="() => OpenTableAsync(sel)">Open table</BoButton>
                    }
                    else
                    {
                        <BoButton Variant="primary" OnClick="() => TakeOrderForTable(sel)">Take order</BoButton>
                        <BoButton Variant="outline" OnClick="() => ViewBillAsync(sel)">View bill</BoButton>
                        <BoButton Variant="outline" OnClick="() => RequestPaymentAsync(sel)">Request payment</BoButton>
                        <BoButton Variant="ghost" OnClick="() => ChangeGuestsAsync(sel)">Guest count</BoButton>
                        <BoButton Variant="ghost" OnClick="() => MoveTableAsync(sel)">Move / transfer table</BoButton>
                        <BoButton Variant="ghost" OnClick="() => MergeTablesAsync(sel)">Merge tables</BoButton>
                        <BoButton Variant="ghost" OnClick="() => SplitTableAsync(sel)">Split session</BoButton>
                        <BoButton Variant="ghost" OnClick="() => TransferWaiterAsync(sel)">Transfer waiter</BoButton>
                        <BoButton Variant="ghost" OnClick="() => PrintKot(sel)">Print KOT</BoButton>
                        <BoButton Variant="ghost" OnClick="() => PrintBill(sel)">Print bill</BoButton>
                        <AuthorizeView Policy="CanCloseSession">
                            <BoButton Variant="danger" OnClick="() => CloseSessionAsync(sel)">Close session</BoButton>
                        </AuthorizeView>
                    }
                </div>
            }
        </div>
    }
    else if (_tab == WaiterTab.Ready)
    {
        <!-- ============ READY TO SERVE ============ -->
        <BoCard Title="Ready to serve">
            <HeaderActions>
                @if (_ready.Count > 0)
                {
                    <BoButton Variant="primary" Size="sm" OnClick="ServeAllAsync">Serve all</BoButton>
                }
            </HeaderActions>
            <ChildContent>
                @if (_ready.Count == 0)
                {
                    <EmptyState Icon="DocumentBulletList" Title="Nothing waiting"
                                Description="Cooked orders ready to carry out will appear here." />
                }
                else
                {
                    <div class="rts-list">
                        @foreach (var r in _ready)
                        {
                            <div class="rts" @key="r.OrderId">
                                <div class="rts-info">
                                    <div class="rts-top">
                                        <strong>@(r.TableNumber ?? "Takeaway")</strong>
                                        <span class="rts-no">@r.OrderNumber</span>
                                        <span class="rts-wait">⏱ @r.WaitingMinutes m</span>
                                    </div>
                                    <div class="rts-items">
                                        @string.Join(", ", r.Items.Select(i => $"{i.Quantity}× {i.Name}"))
                                    </div>
                                </div>
                                <BoButton Variant="primary" Size="sm" OnClick="() => ServeAsync(r.OrderId)">Mark served</BoButton>
                            </div>
                        }
                    </div>
                }
            </ChildContent>
        </BoCard>
    }
    else if (_tab == WaiterTab.Requests)
    {
        <!-- ============ CUSTOMER REQUESTS ============ -->
        <BoCard Title="Customer requests">
            @if (_requests.Count == 0)
            {
                <EmptyState Icon="Send" Title="No pending requests"
                            Description="Call-waiter, bill and other table requests show up here." />
            }
            else
            {
                <div class="req-list">
                    @foreach (var r in _requests)
                    {
                        <div class="req" @key="r.Id">
                            <div class="req-info">
                                <div class="req-top">
                                    <strong>Table @r.TableNumber</strong>
                                    <BoBadge Tone="warning">@RequestLabel(r.Type)</BoBadge>
                                    <span class="req-wait">⏱ @r.WaitingMinutes m</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(r.Note))
                                {
                                    <div class="req-note">@r.Note</div>
                                }
                            </div>
                            <BoButton Variant="primary" Size="sm" OnClick="() => ResolveRequestAsync(r.Id)">Resolve</BoButton>
                        </div>
                    }
                </div>
            }
        </BoCard>
    }
    else
    {
        <!-- ============ TAKE ORDER ============ -->
        <div class="run-bar">
            <span class="run-bar-label">Running orders</span>
            @if (!RunningOrders.Any())
            {
                <span class="run-bar-empty">None right now — new orders show up here.</span>
            }
            else
            {
                @foreach (var o in RunningOrders)
                {
                    <button type="button" @key="o.Id"
                            class="@($"run-chip run-chip--{StatusTone(o.Status)} {(_activeOrder?.Id == o.Id ? "run-chip--active" : "")}")"
                            title="@o.OrderNumber · @o.Status — tap to load and edit this order"
                            @onclick="() => SelectRunningOrderAsync(o)">
                        <span class="run-chip-line1">@ChipTitle(o)</span>
                        <span class="run-chip-line2">
                            @o.Currency @o.Total.ToString("0.##")
                            <span class="run-chip-status">@o.Status</span>
                        </span>
                    </button>
                }
            }
            <button type="button" class="run-refresh" title="Refresh orders" @onclick="LoadActiveOrdersAsync">↻</button>
        </div>

        <div class="pos-workspace">
            <!-- ============ CATEGORY RAIL ============ -->
            <div class="pos-cats">
                <div class="pos-cats-title">Category</div>
                <button type="button" class="pos-cat @(_selectedCategoryId is null ? "pos-cat--active" : null)"
                        @onclick="() => SelectCategory(null)">All</button>
                @foreach (var cat in VisibleCategories)
                {
                    <button type="button" @key="cat.Id"
                            class="pos-cat @(_selectedCategoryId == cat.Id ? "pos-cat--active" : null)"
                            @onclick="() => SelectCategory(cat.Id)">
                        @cat.Name
                    </button>
                }
            </div>

            <!-- ============ PRODUCT GRID ============ -->
            <div class="pos-products">
                @if (_products is null || _products.Count == 0)
                {
                    <EmptyState Icon="DocumentBulletList" Title="No products"
                                Description="Add products from Inventory → Products first." />
                }
                else if (!FilteredProducts.Any())
                {
                    <EmptyState Icon="Search" Title="No items"
                                Description="No products in this category — add some from Inventory → Products." />
                }
                else
                {
                    <div class="pos-prod-grid">
                        @foreach (var item in FilteredProducts)
                        {
                            var outOfStock = IsOutOfStock(item);
                            <div @key="item.Id" class="pos-prod-card @(outOfStock ? "pos-prod-card--out" : "pos-prod-card--tappable")"
                                 title="@(outOfStock ? $"{item.Name} is out of stock" : item.HasVariants ? $"Pick a size for {item.Name}" : $"Tap to add {item.Name}")"
                                 @onclick="() => OnProductClickAsync(item)">
                                <div class="pos-prod-thumb">
                                    @if (outOfStock)
                                    {
                                        <span class="pos-stock-badge pos-stock-badge--out">Out</span>
                                    }
                                    else if (IsLowStock(item))
                                    {
                                        <span class="pos-stock-badge pos-stock-badge--low">Low @(AvailableOf(item)?.ToString("0.#"))</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                                    {
                                        <img src="@item.ImagePath" alt="@item.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <BoIcon Name="Cart" Size="22" />
                                    }
                                </div>
                                <div class="pos-prod-meta">
                                    <span class="pos-prod-cat">@item.Name</span>
                                    <span class="pos-prod-price">
                                        @(item.HasVariants ? $"from {item.Currency} {item.MinPrice:0.##}" : $"{item.Currency} {item.Price:0.##}")
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ============ ORDER PANEL ============ -->
            <div class="pos-order">
                <BoCard Title="@(IsEditMode ? "Edit order" : "Current order")"
                        Subtitle="@(_cart.Count == 0 ? null : $"{_cart.Sum(l => l.Qty)} item(s)")">
                    <HeaderActions>
                        @if (_cart.Count > 0 && !IsEditMode)
                        {
                            <BoButton Variant="ghost" Size="sm" OnClick="ClearCart">Clear</BoButton>
                        }
                    </HeaderActions>
                    <ChildContent>
                        <div class="order-form">
                            @if (IsEditMode)
                            {
                                <div class="append-banner">
                                    <div class="append-banner-text">
                                        <strong>Editing @_activeOrder!.OrderNumber</strong>
                                        <span>@(_activeOrder!.TableNumber is { } tn ? $"Table {tn}" : "Takeaway") · @_activeOrder!.Status — adjust items, then save</span>
                                    </div>
                                    <button type="button" class="append-banner-close" title="Back to new order" @onclick="DeselectOrder">✕</button>
                                </div>
                            }
                            else
                            {
                                <div class="type-toggle">
                                    <button type="button" class="type-btn @(_type == OrderType.DineIn ? "type-btn--active" : null)"
                                            @onclick="() => SetType(OrderType.DineIn)">
                                        🍽️ Dine-in
                                    </button>
                                    <button type="button" class="type-btn @(_type == OrderType.Takeaway ? "type-btn--active" : null)"
                                            @onclick="() => SetType(OrderType.Takeaway)">
                                        🥡 Takeaway
                                    </button>
                                </div>

                                @if (_type == OrderType.DineIn)
                                {
                                    <div class="field-row">
                                        <span class="field-label">Table @(_selectedTable is null ? "· choose one" : $"· {_selectedTable.TableNumber}")@(_currentSessionId is not null ? " · session open" : "")</span>
                                        @if (_tables.Count == 0)
                                        {
                                            <BoMessageBar Intent="warning">No tables configured.</BoMessageBar>
                                        }
                                        else
                                        {
                                            <div class="table-grid">
                                                @foreach (var t in _tables)
                                                {
                                                    <button type="button" @key="t.Id"
                                                            class="table-chip @(_selectedTable?.Id == t.Id ? "table-chip--active" : null)"
                                                            @onclick="() => { _selectedTable = t; _currentSessionId = null; }">
                                                        <span class="table-chip-no">@t.TableNumber</span>
                                                        <span class="table-chip-cap">@t.Capacity seats</span>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                <details class="guest-details" open="@(!string.IsNullOrEmpty(_phone) || !string.IsNullOrEmpty(_name))">
                                    <summary>Guest info (optional)</summary>
                                    <div class="two-col">
                                        <BoInput @bind-Value="_phone" Label="Phone" Placeholder="01XXXXXXXXX" />
                                        <BoInput @bind-Value="_name" Label="Name" />
                                    </div>
                                </details>
                            }

                            @if (_cart.Count == 0)
                            {
                                <div class="cart-empty">
                                    <BoIcon Name="Cart" Size="28" />
                                    <span>@(IsEditMode
                                        ? "All items removed — an order needs at least one item. Cancel the order from the list instead."
                                        : "Tap items on the left to add them.")</span>
                                </div>
                            }
                            else
                            {
                                <div class="cart-lines">
                                    @foreach (var line in _cart)
                                    {
                                        <div class="cart-line" @key="@($"{line.ProductId}:{line.VariantId}:{line.OptKey}")">
                                            <div class="cart-line-info">
                                                <span class="cart-line-name">@line.Name</span>
                                                <span class="cart-line-sub">@line.Currency @line.UnitPrice.ToString("0.##") each</span>
                                                @if (line.Options.Count > 0)
                                                {
                                                    <span class="cart-line-opts">@string.Join(", ", line.Options.Select(o => o.PriceDelta > 0 ? $"{o.Name} (+{o.PriceDelta:0.##})" : o.Name))</span>
                                                }
                                            </div>
                                            <div class="qty">
                                                <button type="button" class="qty-btn" @onclick="() => Decrement(line)">−</button>
                                                <span class="qty-val">@line.Qty</span>
                                                <button type="button" class="qty-btn qty-btn--plus" @onclick="() => Increment(line)">+</button>
                                            </div>
                                            <span class="cart-line-total">@((line.UnitPrice * line.Qty).ToString("0.##"))</span>
                                            <button type="button" class="line-remove" title="Remove" @onclick="() => Remove(line)">✕</button>
                                        </div>
                                    }
                                </div>

                                <div class="cart-total">
                                    <span>Total</span>
                                    <strong>@Currency @Total.ToString("0.##")</strong>
                                </div>
                            }

                            @if (!IsEditMode)
                            {
                                <BoInput @bind-Value="_notes" Label="Kitchen notes (optional)" Placeholder="e.g. no onions, extra spicy" />
                            }

                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <BoMessageBar Intent="error">@_error</BoMessageBar>
                            }

                            <BoButton Variant="primary" OnClick="PlaceAsync" Loading="_placing" Disabled="@(!CanPlace)">
                                @(IsEditMode
                                    ? $"Update {_activeOrder!.OrderNumber} · {Currency} {Total:0.##}"
                                    : _cart.Count == 0 ? "Place order" : $"Place order · {Currency} {Total:0.##}")
                            </BoButton>
                        </div>
                    </ChildContent>
                </BoCard>
            </div>
        </div>
    }
}

<style>
    /* ---------- white card surface for every page section ---------- */
    .wc-section {
        background: var(--bo-bg-card); border: 1px solid var(--bo-border-soft);
        border-radius: var(--bo-radius-lg, 12px); padding: 14px;
    }

    /* ---------- console header / tabs / widgets ---------- */
    .wc-head { display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:14px; }
    .wc-title { display:flex; align-items:center; gap:12px; }
    .wc-title h2 { margin:0; }
    .wc-conn { display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:700; padding:3px 10px; border-radius:999px; }
    .wc-conn--on { background:color-mix(in srgb, var(--bo-success) 14%, transparent); color:var(--bo-success); }
    .wc-conn--off { background:color-mix(in srgb, var(--bo-warning) 14%, transparent); color:var(--bo-warning); }
    .wc-dot { width:8px; height:8px; border-radius:50%; background:currentColor; }
    .wc-tabs { display:flex; gap:4px; padding:4px; background:var(--bo-bg-soft); border-radius:var(--bo-radius-md,10px); border:1px solid var(--bo-border-soft); }
    .wc-tab { padding:8px 16px; border:none; border-radius:8px; cursor:pointer; background:transparent; color:var(--bo-text-muted); font-size:14px; font-weight:600; }
    .wc-tab--active { background:var(--bo-bg-card); color:var(--bo-text); box-shadow:0 1px 3px rgb(0 0 0 / .12); }

    .wc-widgets { display:grid; grid-template-columns:repeat(auto-fit, minmax(120px,1fr)); gap:10px; margin-bottom:16px; }
    .wc-widget { display:flex; flex-direction:column; gap:2px; padding:12px 14px; border-radius:var(--bo-radius-md,10px); background:var(--bo-bg-card); border:1px solid var(--bo-border-soft); }
    .wc-widget--ok { border-left:3px solid var(--bo-success); }
    .wc-widget--warn { border-left:3px solid var(--bo-warning); }
    .wc-widget--info { border-left:3px solid var(--bo-info); }
    .wc-widget--primary { border-left:3px solid var(--bo-primary); }
    .wc-widget--danger { border-left:3px solid var(--bo-danger); }
    .wc-w-num { font-size:22px; font-weight:800; }
    .wc-w-lbl { font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:var(--bo-text-muted); }

    /* ---------- floor ---------- */
    .wc-filters { display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:14px; }
    .flt { padding:7px 14px; border-radius:999px; cursor:pointer; border:1px solid var(--bo-border); background:var(--bo-bg-card); color:var(--bo-text); font-size:13px; font-weight:600; }
    .flt:hover { border-color:var(--bo-primary); color:var(--bo-primary); }
    .flt--active { background:var(--bo-primary); border-color:var(--bo-primary); color:var(--bo-on-primary,#fff); }
    .flt-mine { display:inline-flex; align-items:center; gap:6px; margin-left:8px; font-size:13px; color:var(--bo-text-muted); cursor:pointer; }

    .wc-floor-wrap { display:grid; grid-template-columns:minmax(0,1fr) 300px; gap:16px; align-items:start; }
    @@media (max-width: 980px) { .wc-floor-wrap { grid-template-columns:1fr; } }
    .wc-floor { display:grid; grid-template-columns:repeat(auto-fill, minmax(150px,1fr)); gap:12px; }
    .tbl { display:flex; flex-direction:column; gap:8px; padding:14px; text-align:left; cursor:pointer;
           border:1px solid var(--bo-border); border-radius:var(--bo-radius-lg,12px); background:var(--bo-bg-card); color:var(--bo-text);
           transition:transform .08s, box-shadow .12s, border-color .12s; min-height:120px; }
    .tbl:hover { transform:translateY(-2px); box-shadow:var(--bo-shadow-md, 0 4px 8px rgb(0 0 0 / .08)); }
    .tbl--sel { outline:2px solid var(--bo-primary); outline-offset:1px; }
    .tbl--success { border-top:4px solid var(--bo-success); }
    .tbl--warning { border-top:4px solid var(--bo-warning); }
    .tbl--info { border-top:4px solid var(--bo-info); }
    .tbl--danger { border-top:4px solid var(--bo-danger); }
    .tbl--neutral { border-top:4px solid var(--bo-border-strong); }
    .tbl-top { display:flex; align-items:center; justify-content:space-between; gap:6px; }
    .tbl-no { font-size:20px; font-weight:800; }
    .tbl-meta { display:flex; flex-wrap:wrap; gap:10px; font-size:12px; color:var(--bo-text-muted); }
    .tbl-bill { font-size:16px; font-weight:800; color:var(--bo-primary); }
    .tbl-waiter { font-size:11px; color:var(--bo-text-subtle); }

    .wc-actions { position:sticky; top:16px; display:flex; flex-direction:column; gap:8px;
                  padding:16px; border:1px solid var(--bo-border); border-radius:var(--bo-radius-lg,12px); background:var(--bo-bg-card); }
    .wc-actions-head { display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:4px; }
    .wc-actions ::deep .bo-btn { width:100%; justify-content:center; }

